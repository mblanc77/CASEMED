@page "/imponibles"
@attribute [Authorize]

<PageTitle>Imponibles</PageTitle>
<RadzenStack>
    <RadzenRow AlignItems="AlignItems.Center">
        <RadzenColumn Size="12" SizeMD="6">
            <RadzenText Text="Imponibles" TextStyle="TextStyle.H3" TagName="TagName.H1" style="margin: 0" />
        </RadzenColumn>
        <RadzenColumn Size="12" SizeMD="6">
            <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" JustifyContent="JustifyContent.End" Gap="0.5rem">
                <RadzenSplitButton Icon="get_app" Text="Export" Click="@ExportClick" Variant="Variant.Flat" Shade="Shade.Lighter">
                    <RadzenSplitButtonItem Text="Excel" Value="xlsx" />
                    <RadzenSplitButtonItem Text="CSV" Value="csv" />
                </RadzenSplitButton>
                <RadzenButton Icon="add_circle_outline" Text="Add" Click="@AddButtonClick" Variant="Variant.Flat" />
            </RadzenStack>
        </RadzenColumn>
    </RadzenRow>
    <RadzenRow>
      <RadzenColumn SizeMD=12>
        <RadzenDataGrid @ref="grid0" ColumnWidth="200px"  AllowFiltering="true" FilterMode="FilterMode.Advanced" AllowPaging="true" AllowSorting="true" ShowPagingSummary="true" PageSizeOptions=@(new int[]{5, 10, 20, 30})
            Data="@imponibles" Count=count LoadData=@Grid0LoadData  TItem="SgpaNew.Server.Models.Sgpa.Imponible" RowDoubleClick="@EditRow" >
            <Columns>
                <RadzenDataGridColumn TItem="SgpaNew.Server.Models.Sgpa.Imponible" Property="CI" Title="C I">
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="SgpaNew.Server.Models.Sgpa.Imponible" Property="CodEmpresa" Title="Cod Empresa">
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="SgpaNew.Server.Models.Sgpa.Imponible" Property="Fechaingreso" Title="Fechaingreso">
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="SgpaNew.Server.Models.Sgpa.Imponible" Property="Mes" Title="Mes">
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="SgpaNew.Server.Models.Sgpa.Imponible" Property="Anio" Title="Anio">
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="SgpaNew.Server.Models.Sgpa.Imponible" Property="Concepto" Title="Concepto">
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="SgpaNew.Server.Models.Sgpa.Imponible" Property="DiasTrabajados" Title="Dias Trabajados">
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="SgpaNew.Server.Models.Sgpa.Imponible" Property="Importe" Title="Importe">
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="SgpaNew.Server.Models.Sgpa.Imponible" Property="Usr" Title="Usr">
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="SgpaNew.Server.Models.Sgpa.Imponible" Property="Ts" Title="Ts">
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="SgpaNew.Server.Models.Sgpa.Imponible" Property="AnioMes" Title="Anio Mes">
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="SgpaNew.Server.Models.Sgpa.Imponible" Property="ImponibleId" Title="Imponible Id">
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="SgpaNew.Server.Models.Sgpa.Imponible" Property="Trabaja.NroFichaEmpresa" Title="Trabaja">
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="SgpaNew.Server.Models.Sgpa.Imponible" Filterable="false" Sortable="false" Width="70px" TextAlign="TextAlign.Center">
                    <Template Context="imponible">

                        <RadzenButton ButtonStyle="ButtonStyle.Danger" Icon="delete" Size="ButtonSize.Medium"
                            Shade="Shade.Lighter" Variant="Variant.Flat"
                            Click=@(args => GridDeleteButtonClick(args, imponible)) @onclick:stopPropagation="true" />
                    </Template>
                </RadzenDataGridColumn>
            </Columns>

        </RadzenDataGrid>

    </RadzenColumn>
  </RadzenRow>
</RadzenStack>
