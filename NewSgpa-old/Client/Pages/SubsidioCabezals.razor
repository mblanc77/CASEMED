                <RadzenDataGridColumn TItem="SgpaNew.Server.Models.Sgpa.SubsidioCabezal" Property="Anio" Title="Anio">
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="SgpaNew.Server.Models.Sgpa.SubsidioCabezal" Property="Liquidar" Title="Liquidar">
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="SgpaNew.Server.Models.Sgpa.SubsidioCabezal" Property="ValorJornal" Title="Valor Jornal">
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="SgpaNew.Server.Models.Sgpa.SubsidioCabezal" Property="Dias" Title="Dias">
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="SgpaNew.Server.Models.Sgpa.SubsidioCabezal" Property="ImpNominal" Title="Imp Nominal">
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="SgpaNew.Server.Models.Sgpa.SubsidioCabezal" Property="ImpAguinaldo" Title="Imp Aguinaldo">
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="SgpaNew.Server.Models.Sgpa.SubsidioCabezal" Property="ImpLiquido" Title="Imp Liquido">
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="SgpaNew.Server.Models.Sgpa.SubsidioCabezal" Property="NroRecibo" Title="Nro Recibo">
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="SgpaNew.Server.Models.Sgpa.SubsidioCabezal" Property="FechaPago" Title="Fecha Pago">
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="SgpaNew.Server.Models.Sgpa.SubsidioCabezal" Property="CodBanco" Title="Cod Banco">
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="SgpaNew.Server.Models.Sgpa.SubsidioCabezal" Property="NroCuenta" Title="Nro Cuenta">
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="SgpaNew.Server.Models.Sgpa.SubsidioCabezal" Property="Usr" Title="Usr">
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="SgpaNew.Server.Models.Sgpa.SubsidioCabezal" Property="Ts" Title="Ts">
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="SgpaNew.Server.Models.Sgpa.SubsidioCabezal" Property="Afiliado.Nombres" Title="Afiliado">
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="SgpaNew.Server.Models.Sgpa.SubsidioCabezal" Filterable="false" Sortable="false" Width="70px" TextAlign="TextAlign.Center">
                    <Template Context="subsidioCabezal">

                        <RadzenButton ButtonStyle="ButtonStyle.Danger" Icon="delete" Size="ButtonSize.Medium"
                            Shade="Shade.Lighter" Variant="Variant.Flat"
                            Click=@(args => GridDeleteButtonClick(args, subsidioCabezal)) @onclick:stopPropagation="true" />
                    </Template>
                </RadzenDataGridColumn>
            </Columns>

        </RadzenDataGrid>

    </RadzenColumn>
  </RadzenRow>
</RadzenStack>
