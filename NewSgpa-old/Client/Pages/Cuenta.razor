@page "/cuenta"
@attribute [Authorize]

<PageTitle>Cuenta</PageTitle>
<RadzenStack>
    <RadzenRow AlignItems="AlignItems.Center">
        <RadzenColumn Size="12" SizeMD="6">
            <RadzenText Text="Cuenta" TextStyle="TextStyle.H3" TagName="TagName.H1" style="margin: 0" />
        </RadzenColumn>
        <RadzenColumn Size="12" SizeMD="6">
            <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" JustifyContent="JustifyContent.End" Gap="0.5rem">
                <RadzenSplitButton Icon="get_app" Text="Export" Click="@ExportClick" Variant="Variant.Flat" Shade="Shade.Lighter">
                    <RadzenSplitButtonItem Text="Excel" Value="xlsx" />
                    <RadzenSplitButtonItem Text="CSV" Value="csv" />
                </RadzenSplitButton>
            </RadzenStack>
        </RadzenColumn>
    </RadzenRow>
    <RadzenRow>
      <RadzenColumn SizeMD=12>
        <RadzenDataGrid @ref="grid0" ColumnWidth="200px"  AllowFiltering="true" FilterMode="FilterMode.Advanced" AllowPaging="true" AllowSorting="true" ShowPagingSummary="true" PageSizeOptions=@(new int[]{5, 10, 20, 30})
            Data="@cuenta" Count=count LoadData=@Grid0LoadData  TItem="SgpaNew.Server.Models.Sgpa.Cuentum" >
            <Columns>
                <RadzenDataGridColumn TItem="SgpaNew.Server.Models.Sgpa.Cuentum" Property="CI" Title="C I">
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="SgpaNew.Server.Models.Sgpa.Cuentum" Property="CodBanco" Title="Cod Banco">
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="SgpaNew.Server.Models.Sgpa.Cuentum" Property="NroCuenta" Title="Nro Cuenta">
                </RadzenDataGridColumn>
            </Columns>

        </RadzenDataGrid>

    </RadzenColumn>
  </RadzenRow>
</RadzenStack>
