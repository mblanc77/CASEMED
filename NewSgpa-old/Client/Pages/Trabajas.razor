@page "/trabajas"
@attribute [Authorize]

<PageTitle>Trabajas</PageTitle>
<RadzenStack>
    <RadzenRow AlignItems="AlignItems.Center">
        <RadzenColumn Size="12" SizeMD="6">
            <RadzenText Text="Trabajas" TextStyle="TextStyle.H3" TagName="TagName.H1" style="margin: 0" />
        </RadzenColumn>
        <RadzenColumn Size="12" SizeMD="6">
            <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" JustifyContent="JustifyContent.End" Gap="0.5rem">
                <RadzenSplitButton Icon="get_app" Text="Export" Click="@ExportClick" Variant="Variant.Flat" Shade="Shade.Lighter">
                    <RadzenSplitButtonItem Text="Excel" Value="xlsx" />
                    <RadzenSplitButtonItem Text="CSV" Value="csv" />
                </RadzenSplitButton>
                <RadzenButton Icon="add_circle_outline" Text="Add" Click="@AddButtonClick" Variant="Variant.Flat" />
            </RadzenStack>
        </RadzenColumn>
    </RadzenRow>
    <RadzenRow>
      <RadzenColumn SizeMD=12>
        <RadzenDataGrid @ref="grid0" ColumnWidth="200px"  AllowFiltering="true" FilterMode="FilterMode.Advanced" AllowPaging="true" AllowSorting="true" ShowPagingSummary="true" PageSizeOptions=@(new int[]{5, 10, 20, 30})
            Data="@trabajas" Count=count LoadData=@Grid0LoadData  TItem="SgpaNew.Server.Models.Sgpa.Trabaja" RowDoubleClick="@EditRow" >
            <Columns>
                <RadzenDataGridColumn TItem="SgpaNew.Server.Models.Sgpa.Trabaja" Property="FechaIngreso" Title="Fecha Ingreso">
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="SgpaNew.Server.Models.Sgpa.Trabaja" Property="FechaBaja" Title="Fecha Baja">
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="SgpaNew.Server.Models.Sgpa.Trabaja" Property="NroFichaEmpresa" Title="Nro Ficha Empresa">
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="SgpaNew.Server.Models.Sgpa.Trabaja" Property="IdTrabaja" Title="Id Trabaja">
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="SgpaNew.Server.Models.Sgpa.Trabaja" Property="FechaIngCasemed" Title="Fecha Ing Casemed">
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="SgpaNew.Server.Models.Sgpa.Trabaja" Property="Usr" Title="Usr">
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="SgpaNew.Server.Models.Sgpa.Trabaja" Property="Ts" Title="Ts">
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="SgpaNew.Server.Models.Sgpa.Trabaja" Property="Afiliado.Nombres" Title="Afiliado">
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="SgpaNew.Server.Models.Sgpa.Trabaja" Property="BajaMotivo.Descrip" Title="Baja Motivo">
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="SgpaNew.Server.Models.Sgpa.Trabaja" Property="Empresa.Nombre" Title="Empresa">
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="SgpaNew.Server.Models.Sgpa.Trabaja" Filterable="false" Sortable="false" Width="70px" TextAlign="TextAlign.Center">
                    <Template Context="trabaja">

                        <RadzenButton ButtonStyle="ButtonStyle.Danger" Icon="delete" Size="ButtonSize.Medium"
                            Shade="Shade.Lighter" Variant="Variant.Flat"
                            Click=@(args => GridDeleteButtonClick(args, trabaja)) @onclick:stopPropagation="true" />
                    </Template>
                </RadzenDataGridColumn>
            </Columns>

        </RadzenDataGrid>

    </RadzenColumn>
  </RadzenRow>
</RadzenStack>
