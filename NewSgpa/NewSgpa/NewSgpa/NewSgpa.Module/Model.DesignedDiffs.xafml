<?xml version="1.0" ?>
<Application Title="NewSgpa" Company="CASEMED" Copyright="© CASEMED" Description="Sistema de Gestión de Prestaciones y Aportes">
  <BOModel>
    <Class Name="DevExpress.Persistent.BaseImpl.EF.PermissionPolicy.PermissionPolicyUser" Caption="Base User" />
    <!-- === SGPA Core === -->
    <Class Name="NewSgpa.Module.BusinessObjects.Sgpa.Afiliado" Caption="Afiliado" ImageName="BO_Contact">
      <OwnMembers>
        <Member Name="CI" Caption="Cédula" DisplayFormat="{0:N0}" />
        <Member Name="Nombres" Caption="Nombres" />
        <Member Name="Apellido1" Caption="1er Apellido" />
        <Member Name="Apellido2" Caption="2do Apellido" />
        <Member Name="FechaNacimiento" Caption="Fecha Nacimiento" DisplayFormat="{0:dd/MM/yyyy}" />
        <Member Name="Sexo" Caption="Sexo" />
        <Member Name="Direccion" Caption="Dirección" />
        <Member Name="Telefono" Caption="Teléfono" />
        <Member Name="Movil" Caption="Celular" />
        <Member Name="CodMutualista" Caption="Mutualista" />
        <Member Name="FechaIngMutualista" Caption="Ingreso Mutualista" DisplayFormat="{0:dd/MM/yyyy}" />
        <Member Name="FechaBajaMutualista" Caption="Baja Mutualista" DisplayFormat="{0:dd/MM/yyyy}" />
        <Member Name="NroSocioMutualista" Caption="Nro. Socio" />
        <Member Name="CodRegimenJubilatorio" Caption="Régimen Jubilatorio" />
        <Member Name="CodDepartamento" Caption="Departamento" />
        <Member Name="PagaMutualista" Caption="Paga Mutualista" />
        <Member Name="CodSituacionMutual" Caption="Sit. Mutual" />
        <Member Name="CodBanco" Caption="Banco" />
        <Member Name="NroCuenta" Caption="Nro. Cuenta" />
        <Member Name="NroFunCuenta" Caption="Nro. Fun. Cuenta" />
        <Member Name="Usr" Caption="Usuario" />
        <Member Name="Ts" Caption="Timestamp" DisplayFormat="{0:dd/MM/yyyy HH:mm}" />
      </OwnMembers>
    </Class>
    <Class Name="NewSgpa.Module.BusinessObjects.Sgpa.AfiliadoApunte" Caption="Apunte" ImageName="BO_Note">
      <OwnMembers>
        <Member Name="Fecha" Caption="Fecha" DisplayFormat="{0:dd/MM/yyyy}" />
        <Member Name="Descrip" Caption="Descripción" />
      </OwnMembers>
    </Class>
    <Class Name="NewSgpa.Module.BusinessObjects.Sgpa.Trabaja" Caption="Empleo" ImageName="BO_Organization">
      <OwnMembers>
        <Member Name="FechaIngreso" Caption="Fecha Ingreso" DisplayFormat="{0:dd/MM/yyyy}" />
        <Member Name="FechaBaja" Caption="Fecha Baja" DisplayFormat="{0:dd/MM/yyyy}" />
        <Member Name="FechaIngCasemed" Caption="Ingreso CASEMED" DisplayFormat="{0:dd/MM/yyyy}" />
        <Member Name="NroFichaEmpresa" Caption="Nro. Ficha" />
      </OwnMembers>
    </Class>
    <Class Name="NewSgpa.Module.BusinessObjects.Sgpa.Certificacion" Caption="Certificación" ImageName="BO_Audit_ChangeHistory">
      <OwnMembers>
        <Member Name="NroLlamado" Caption="Nro. Llamado" />
        <Member Name="FechaRecibido" Caption="Recibido" DisplayFormat="{0:dd/MM/yyyy}" />
        <Member Name="FechaCertificacion" Caption="Certificación" DisplayFormat="{0:dd/MM/yyyy}" />
        <Member Name="FechaIni" Caption="Desde" DisplayFormat="{0:dd/MM/yyyy}" />
        <Member Name="FechaFin" Caption="Hasta" DisplayFormat="{0:dd/MM/yyyy}" />
        <Member Name="Efectiva" Caption="Efectiva" />
        <Member Name="ImporteDeducible" Caption="Imp. Deducible" DisplayFormat="{0:N2}" />
        <Member Name="TrabajaDuranteCertificacion" Caption="Trabaja" />
      </OwnMembers>
    </Class>
    <Class Name="NewSgpa.Module.BusinessObjects.Sgpa.Prestacion" Caption="Prestación" ImageName="BO_Invoice">
      <OwnMembers>
        <Member Name="Fecha" Caption="Fecha" DisplayFormat="{0:dd/MM/yyyy}" />
        <Member Name="Importe" Caption="Importe" DisplayFormat="{0:N2}" />
        <Member Name="Moneda" Caption="Moneda" />
        <Member Name="Boleta" Caption="Boleta" />
      </OwnMembers>
    </Class>
    <Class Name="NewSgpa.Module.BusinessObjects.Sgpa.Receta" Caption="Receta" ImageName="BO_FileAttachment" />
    <Class Name="NewSgpa.Module.BusinessObjects.Sgpa.Imponible" Caption="Imponible" ImageName="BO_Sale">
      <OwnMembers>
        <Member Name="Importe" Caption="Importe" DisplayFormat="{0:N2}" />
        <Member Name="Concepto" Caption="Concepto" />
        <Member Name="DiasTrabajados" Caption="Días Trab." />
        <Member Name="AnioMes" Caption="Período" />
      </OwnMembers>
    </Class>
    <Class Name="NewSgpa.Module.BusinessObjects.Sgpa.ReintegroMutual" Caption="Reintegro Mutual" ImageName="BO_Contract">
      <OwnMembers>
        <Member Name="Fecha" Caption="Fecha" DisplayFormat="{0:dd/MM/yyyy}" />
        <Member Name="Importe" Caption="Importe" DisplayFormat="{0:N2}" />
      </OwnMembers>
    </Class>
    <!-- === Subsidios === -->
    <Class Name="NewSgpa.Module.BusinessObjects.Sgpa.SubsidioCabezal" Caption="Subsidio" ImageName="BO_Sale">
      <OwnMembers>
        <Member Name="IdSubsidio" Caption="ID" />
        <Member Name="Mes" Caption="Mes" />
        <Member Name="Anio" Caption="Año" />
        <Member Name="Liquidar" Caption="Liquidar" />
        <Member Name="ValorJornal" Caption="Valor Jornal" DisplayFormat="{0:N3}" />
        <Member Name="Dias" Caption="Días" />
        <Member Name="ImpNominal" Caption="Nominal" DisplayFormat="{0:N2}" />
        <Member Name="ImpAguinaldo" Caption="Aguinaldo" DisplayFormat="{0:N2}" />
        <Member Name="ImpLiquido" Caption="Líquido" DisplayFormat="{0:N2}" />
        <Member Name="NroRecibo" Caption="Nro. Recibo" />
        <Member Name="FechaPago" Caption="Fecha Pago" DisplayFormat="{0:dd/MM/yyyy}" />
      </OwnMembers>
    </Class>
    <Class Name="NewSgpa.Module.BusinessObjects.Sgpa.SubsidioCabezalEmpresa" Caption="Subsidio x Empresa" />
    <Class Name="NewSgpa.Module.BusinessObjects.Sgpa.SubsidioItem" Caption="Ítem Subsidio" />
    <Class Name="NewSgpa.Module.BusinessObjects.Sgpa.SubsidioEnfermedad" Caption="Enfermedad" />
    <Class Name="NewSgpa.Module.BusinessObjects.Sgpa.SubsidioCabezalBps" Caption="BPS" />
    <Class Name="NewSgpa.Module.BusinessObjects.Sgpa.SubsidioItemCod" Caption="Código Ítem" />
    <Class Name="NewSgpa.Module.BusinessObjects.Sgpa.SubsidioItemCodAfiliado" Caption="Ítem x Afiliado" />
    <!-- === Lookups === -->
    <Class Name="NewSgpa.Module.BusinessObjects.Sgpa.Mutualista" Caption="Mutualista" ImageName="BO_Organization" />
    <Class Name="NewSgpa.Module.BusinessObjects.Sgpa.Empresa" Caption="Empresa" ImageName="BO_Department" />
    <Class Name="NewSgpa.Module.BusinessObjects.Sgpa.Certificador" Caption="Certificador" ImageName="BO_Employee" />
    <Class Name="NewSgpa.Module.BusinessObjects.Sgpa.Patologia" Caption="Patología" />
