  <Options>
    <LayoutManagerOptions RequiredFieldMark="*" />
  </Options>
  <Views>
    <ListView Id="ApplicationUser_ListView" Caption="Users" />
    <!-- === Afiliado ListView: Key columns === -->
    <ListView Id="Afiliado_ListView" Caption="Afiliados" AllowEdit="False">
      <Columns>
        <ColumnInfo Id="CI" SortIndex="0" SortOrder="Ascending" Width="100" Index="0" />
        <ColumnInfo Id="Apellido1" Width="120" Index="1" />
        <ColumnInfo Id="Apellido2" Width="120" Index="2" />
        <ColumnInfo Id="Nombres" Width="120" Index="3" />
        <ColumnInfo Id="Mutualista" Width="150" Index="4" />
        <ColumnInfo Id="CodSituacionMutual" Width="60" Index="5" Caption="Sit." />
        <ColumnInfo Id="Telefono" Width="100" Index="6" />
        <ColumnInfo Id="Movil" Width="100" Index="7" />
      </Columns>
    </ListView>
    <!-- === Certificacion ListView === -->
    <ListView Id="Certificacion_ListView" Caption="Certificaciones" AllowEdit="False">
      <Columns>
        <ColumnInfo Id="CI" Width="90" Index="0" />
        <ColumnInfo Id="Afiliado" Width="180" Index="1" />
        <ColumnInfo Id="FechaIni" Width="100" Index="2" />
        <ColumnInfo Id="FechaFin" Width="100" Index="3" />
        <ColumnInfo Id="AfeccionTipo" Width="150" Index="4" />
        <ColumnInfo Id="Certificador" Width="120" Index="5" />
        <ColumnInfo Id="Efectiva" Width="60" Index="6" />
        <ColumnInfo Id="SalidaTipo" Width="100" Index="7" />
      </Columns>
    </ListView>
    <!-- === SubsidioCabezal ListView === -->
    <ListView Id="SubsidioCabezal_ListView" Caption="Subsidios" AllowEdit="False">
      <Columns>
        <ColumnInfo Id="IdSubsidio" Width="60" Index="0" />
        <ColumnInfo Id="CI" Width="90" Index="1" />
        <ColumnInfo Id="Afiliado" Width="180" Index="2" />
        <ColumnInfo Id="Anio" Width="50" Index="3" />
        <ColumnInfo Id="Mes" Width="40" Index="4" />
        <ColumnInfo Id="Dias" Width="50" Index="5" />
        <ColumnInfo Id="ValorJornal" Width="90" Index="6" />
        <ColumnInfo Id="ImpNominal" Width="90" Index="7" />
        <ColumnInfo Id="ImpAguinaldo" Width="90" Index="8" />
        <ColumnInfo Id="ImpLiquido" Width="90" Index="9" />
        <ColumnInfo Id="Liquidar" Width="60" Index="10" />
        <ColumnInfo Id="NroRecibo" Width="80" Index="11" />
      </Columns>
    </ListView>
    <!-- === Imponible ListView === -->
    <ListView Id="Imponible_ListView" Caption="Imponibles" AllowEdit="False">
      <Columns>
        <ColumnInfo Id="CI" Width="90" Index="0" />
        <ColumnInfo Id="CodEmpresa" Width="80" Index="1" />
        <ColumnInfo Id="AnioMes" Width="70" Index="2" SortIndex="0" SortOrder="Descending" />
        <ColumnInfo Id="Concepto" Width="80" Index="3" />
        <ColumnInfo Id="DiasTrabajados" Width="60" Index="4" />
        <ColumnInfo Id="Importe" Width="100" Index="5" />
      </Columns>
    </ListView>
    <!-- === Prestacion ListView === -->
    <ListView Id="Prestacion_ListView" Caption="Prestaciones" AllowEdit="False">
      <Columns>
        <ColumnInfo Id="CI" Width="90" Index="0" />
        <ColumnInfo Id="Afiliado" Width="180" Index="1" />
        <ColumnInfo Id="Fecha" Width="100" Index="2" SortIndex="0" SortOrder="Descending" />
        <ColumnInfo Id="PrestacionTipo" Width="150" Index="3" />
        <ColumnInfo Id="Moneda" Width="50" Index="4" />
        <ColumnInfo Id="Importe" Width="100" Index="5" />
      </Columns>
    </ListView>
    <!-- === SpPrestamo ListView === -->
    <ListView Id="SpPrestamo_ListView" Caption="Préstamos" AllowEdit="False">
      <Columns>
        <ColumnInfo Id="IDPrestamo" Width="60" Index="0" />
        <ColumnInfo Id="CI" Width="90" Index="1" />
        <ColumnInfo Id="Fecha" Width="100" Index="2" SortIndex="0" SortOrder="Descending" />
        <ColumnInfo Id="CodMoneda" Width="50" Index="3" />
        <ColumnInfo Id="Importe" Width="100" Index="4" />
        <ColumnInfo Id="Cuotas" Width="60" Index="5" />
        <ColumnInfo Id="ImporteCuota" Width="90" Index="6" />
        <ColumnInfo Id="PrestamoEstado" Width="100" Index="7" />
      </Columns>
    </ListView>
    <!-- === Afiliado DetailView Layout === -->
    <DetailView Id="Afiliado_DetailView" Caption="Afiliado">
      <Layout>
        <LayoutGroup Id="Main" Direction="Horizontal">
          <LayoutGroup Id="DatosPersonales" Caption="Datos Personales" Direction="Vertical" RelativeSize="50" ShowCaption="True">
            <LayoutItem Id="CI" ViewItem="CI" Index="0" />
            <LayoutItem Id="Nombres" ViewItem="Nombres" Index="1" />
            <LayoutItem Id="Apellido1" ViewItem="Apellido1" Index="2" />
            <LayoutItem Id="Apellido2" ViewItem="Apellido2" Index="3" />
            <LayoutItem Id="FechaNacimiento" ViewItem="FechaNacimiento" Index="4" />
            <LayoutItem Id="Sexo" ViewItem="Sexo" Index="5" />
            <LayoutItem Id="Direccion" ViewItem="Direccion" Index="6" />
            <LayoutItem Id="Telefono" ViewItem="Telefono" Index="7" />
            <LayoutItem Id="Movil" ViewItem="Movil" Index="8" />
            <LayoutItem Id="EMail" ViewItem="EMail" Index="9" />
            <LayoutItem Id="Departamento" ViewItem="Departamento" Index="10" />
          </LayoutGroup>
          <LayoutGroup Id="DatosMutualista" Caption="Mutualista y Banco" Direction="Vertical" RelativeSize="50" ShowCaption="True">
            <LayoutItem Id="Mutualista" ViewItem="Mutualista" Index="0" />
            <LayoutItem Id="SituacionMutual" ViewItem="SituacionMutual" Index="1" />
            <LayoutItem Id="PagaMutualista" ViewItem="PagaMutualista" Index="2" />
            <LayoutItem Id="FechaIngMutualista" ViewItem="FechaIngMutualista" Index="3" />
            <LayoutItem Id="FechaBajaMutualista" ViewItem="FechaBajaMutualista" Index="4" />
            <LayoutItem Id="NroSocioMutualista" ViewItem="NroSocioMutualista" Index="5" />
            <LayoutItem Id="RegimenJubilatorio" ViewItem="RegimenJubilatorio" Index="6" />
            <LayoutItem Id="Banco" ViewItem="Banco" Index="7" />
            <LayoutItem Id="NroCuenta" ViewItem="NroCuenta" Index="8" />
            <LayoutItem Id="NroFunCuenta" ViewItem="NroFunCuenta" Index="9" />
          </LayoutGroup>
        </LayoutGroup>
      </Layout>
      <Items>
        <PropertyEditor Id="CI" Caption="Cédula" />
      </Items>
    </DetailView>
    <DetailView Id="ReportDataV2_DetailView">
      <Layout>
        <LayoutGroup Id="Main" >
          <LayoutGroup Id="SimpleEditors" >
            <LayoutGroup Id="ReportDataV2" >
              <LayoutItem Id="DisplayName" ViewItem="DisplayName" Index="0" IsNewNode="True" Removed="True" />
              <LayoutItem Id="ParametersObjectType" ViewItem="ParametersObjectType" Index="1" IsNewNode="True" Removed="True" />
              <LayoutItem Id="DataTypeCaption" ViewItem="DataTypeCaption" Index="2" IsNewNode="True" Removed="True" />
              <LayoutItem Id="IsInplaceReport" Index="3" />
            </LayoutGroup>
          </LayoutGroup>
        </LayoutGroup>
      </Layout>
    </DetailView>
  </Views>
</Application>
