    <Class Name="NewSgpa.Module.BusinessObjects.Sgpa.BajaMotivo" Caption="Motivo Baja" />
    <Class Name="NewSgpa.Module.BusinessObjects.Sgpa.Banco" Caption="Banco" />
    <Class Name="NewSgpa.Module.BusinessObjects.Sgpa.FormaPago" Caption="Forma de Pago" />
    <Class Name="NewSgpa.Module.BusinessObjects.Sgpa.Especialidad" Caption="Especialidad" />
    <Class Name="NewSgpa.Module.BusinessObjects.Sgpa.Departamento" Caption="Departamento" />
    <Class Name="NewSgpa.Module.BusinessObjects.Sgpa.PrestacionTipo" Caption="Tipo Prestación" />
    <Class Name="NewSgpa.Module.BusinessObjects.Sgpa.Parametros" Caption="Parámetros" ImageName="Action_Inline_Edit" />
    <!-- === Préstamos === -->
    <Class Name="NewSgpa.Module.BusinessObjects.Prestamos.SpPrestamo" Caption="Préstamo" ImageName="BO_Sale" />
    <Class Name="NewSgpa.Module.BusinessObjects.Prestamos.SpFactura" Caption="Factura" ImageName="BO_Invoice" />
    <Class Name="NewSgpa.Module.BusinessObjects.Prestamos.SpCuota" Caption="Cuota" />
    <Class Name="NewSgpa.Module.BusinessObjects.Prestamos.SpPago" Caption="Pago" />
    <Class Name="NewSgpa.Module.BusinessObjects.Prestamos.SpCuadroAmortizacion" Caption="Cuadro Amortización" />
    <Class Name="NewSgpa.Module.BusinessObjects.Prestamos.SpRetencion" Caption="Retención" />
    <Class Name="NewSgpa.Module.BusinessObjects.Sgpa.AdPreJubPago" Caption="Pago Pre-Jub.">
      <OwnMembers>
        <Member Name="Fecha" Caption="Fecha" DisplayFormat="{0:dd/MM/yyyy}" />
        <Member Name="Importe" Caption="Importe" DisplayFormat="{0:N2}" />
      </OwnMembers>
    </Class>
  </BOModel>
