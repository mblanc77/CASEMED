@page "/kpi-definitions"

<PageTitle>KpiDefinitions</PageTitle>
<RadzenStack>
    <RadzenRow AlignItems="AlignItems.Center">
        <RadzenColumn Size="12" SizeMD="6">
            <RadzenText Text="KpiDefinitions" TextStyle="TextStyle.H3" TagName="TagName.H1" style="margin: 0" />
        </RadzenColumn>
        <RadzenColumn Size="12" SizeMD="6">
            <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" JustifyContent="JustifyContent.End" Gap="0.5rem">
                <RadzenSplitButton Icon="get_app" Text="Export" Click="@ExportClick" Variant="Variant.Flat" Shade="Shade.Lighter">
                    <RadzenSplitButtonItem Text="Excel" Value="xlsx" />
                    <RadzenSplitButtonItem Text="CSV" Value="csv" />
                </RadzenSplitButton>
                <RadzenButton Icon="add_circle_outline" Text="Add" Click="@AddButtonClick" Variant="Variant.Flat" />
            </RadzenStack>
        </RadzenColumn>
    </RadzenRow>
    <RadzenRow>
      <RadzenColumn SizeMD=12>
        <RadzenDataGrid @ref="grid0" ColumnWidth="200px"  AllowFiltering="true" FilterMode="FilterMode.Advanced" AllowPaging="true" AllowSorting="true" ShowPagingSummary="true" PageSizeOptions=@(new int[]{5, 10, 20, 30})
            Data="@kpiDefinitions" Count=count LoadData=@Grid0LoadData  TItem="SGPA.Server.Models.CMU.KpiDefinition" RowDoubleClick="@EditRow" >
            <Columns>
                <RadzenDataGridColumn TItem="SGPA.Server.Models.CMU.KpiDefinition" Property="Oid" Title="Oid">
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="SGPA.Server.Models.CMU.KpiDefinition" Property="TargetObjectType" Title="Target Object Type">
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="SGPA.Server.Models.CMU.KpiDefinition" Property="Changed" Title="Changed">
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="SGPA.Server.Models.CMU.KpiDefinition" Property="Name" Title="Name">
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="SGPA.Server.Models.CMU.KpiDefinition" Property="Active" Title="Active">
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="SGPA.Server.Models.CMU.KpiDefinition" Property="Criteria" Title="Criteria">
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="SGPA.Server.Models.CMU.KpiDefinition" Property="Expression" Title="Expression">
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="SGPA.Server.Models.CMU.KpiDefinition" Property="GreenZone" Title="Green Zone">
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="SGPA.Server.Models.CMU.KpiDefinition" Property="RedZone" Title="Red Zone">
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="SGPA.Server.Models.CMU.KpiDefinition" Property="Range" Title="Range">
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="SGPA.Server.Models.CMU.KpiDefinition" Property="Compare" Title="Compare">
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="SGPA.Server.Models.CMU.KpiDefinition" Property="RangeToCompare" Title="Range To Compare">
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="SGPA.Server.Models.CMU.KpiDefinition" Property="MeasurementFrequency" Title="Measurement Frequency">
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="SGPA.Server.Models.CMU.KpiDefinition" Property="MeasurementMode" Title="Measurement Mode">
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="SGPA.Server.Models.CMU.KpiDefinition" Property="Direction" Title="Direction">
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="SGPA.Server.Models.CMU.KpiDefinition" Property="ChangedOn" Title="Changed On">
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="SGPA.Server.Models.CMU.KpiDefinition" Property="SuppressedSeries" Title="Suppressed Series">
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="SGPA.Server.Models.CMU.KpiDefinition" Property="EnableCustomizeRepresentation" Title="Enable Customize Representation">
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="SGPA.Server.Models.CMU.KpiDefinition" Property="OptimisticLockField" Title="Optimistic Lock Field">
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="SGPA.Server.Models.CMU.KpiDefinition" Property="GCRecord" Title="G C Record">
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="SGPA.Server.Models.CMU.KpiDefinition" Property="KpiInstance1.Settings" Title="Kpi Instance1">
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="SGPA.Server.Models.CMU.KpiDefinition" Filterable="false" Sortable="false" Width="70px" TextAlign="TextAlign.Center">
                    <Template Context="kpiDefinition">

                        <RadzenButton ButtonStyle="ButtonStyle.Danger" Icon="delete" Size="ButtonSize.Medium"
                            Shade="Shade.Lighter" Variant="Variant.Flat"
                            Click=@(args => GridDeleteButtonClick(args, kpiDefinition)) @onclick:stopPropagation="true" />
                    </Template>
                </RadzenDataGridColumn>
            </Columns>

        </RadzenDataGrid>

    </RadzenColumn>
  </RadzenRow>
</RadzenStack>
