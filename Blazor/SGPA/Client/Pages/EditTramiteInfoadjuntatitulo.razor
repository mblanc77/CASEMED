@page "/edit-tramite-infoadjuntatitulo"

<PageTitle>Edit TramiteInfoadjuntatitulo</PageTitle>
<RadzenRow>
    <RadzenColumn SizeMD="9">
    <RadzenLabel style="font-weight: bold" Text="Item no longer available." Visible="@(!canEdit)" />
    </RadzenColumn>
    <RadzenColumn SizeMD="3">
    <RadzenButton ButtonStyle="ButtonStyle.Secondary" style="margin-bottom: 20px" Text="Close" Visible="@(!canEdit)" Click="@CancelButtonClick" />
    </RadzenColumn>
</RadzenRow>
<RadzenRow>
    <RadzenColumn SizeMD="9">
    <RadzenLabel style="font-weight: bold" Text="Another user has made conflicting changes to one or more of the fields you have modified. Please reload." Visible="@hasChanges" />
    </RadzenColumn>
    <RadzenColumn SizeMD="3">
    <RadzenButton ButtonStyle="ButtonStyle.Secondary" Icon="autorenew" style="margin-bottom: 20px" Text="Reload" Visible="@hasChanges" Click="@ReloadButtonClick" />
    </RadzenColumn>
</RadzenRow>

    <RadzenColumn SizeMD=12>
        <RadzenAlert Shade="Shade.Lighter" Variant="Variant.Flat" Size="AlertSize.Small" AlertStyle="AlertStyle.Danger" Visible="@errorVisible">Cannot save TramiteInfoadjuntatitulo</RadzenAlert>
        <RadzenTemplateForm TItem="SGPA.Server.Models.CMU.TramiteInfoadjuntatitulo" Data="@tramiteInfoadjuntatitulo" Visible="@(tramiteInfoadjuntatitulo != null && canEdit)" Submit="@FormSubmit">
            <RadzenRow style="margin-bottom: 1rem">
                <RadzenColumn SizeMD="3">
                    <RadzenLabel Text="Fecha Titulo" Component="FechaTitulo" style="width: 100%" />
                </RadzenColumn>
                <RadzenColumn SizeMD="9">
                    <RadzenDatePicker DateFormat="MM/dd/yyyy" style="display: block; width: 100%" @bind-Value="@tramiteInfoadjuntatitulo.FechaTitulo" Name="FechaTitulo" />
                </RadzenColumn>
            </RadzenRow>
            <RadzenRow style="margin-bottom: 1rem">
                <RadzenColumn SizeMD="3">
                    <RadzenLabel Text="Identificador Frente" Component="IdentificadorFrente" style="width: 100%" />
                </RadzenColumn>
                <RadzenColumn SizeMD="9">
                    <RadzenTextBox style="display: block; width: 100%" @bind-Value="@tramiteInfoadjuntatitulo.IdentificadorFrente" Name="IdentificadorFrente" />
                </RadzenColumn>
            </RadzenRow>
            <RadzenRow style="margin-bottom: 1rem">
                <RadzenColumn SizeMD="3">
                    <RadzenLabel Text="Identificador Reverso" Component="IdentificadorReverso" style="width: 100%" />
                </RadzenColumn>
                <RadzenColumn SizeMD="9">
                    <RadzenTextBox style="display: block; width: 100%" @bind-Value="@tramiteInfoadjuntatitulo.IdentificadorReverso" Name="IdentificadorReverso" />
                </RadzenColumn>
            </RadzenRow>
            <RadzenRow style="margin-bottom: 1rem">
                <RadzenColumn SizeMD="3">
                    <RadzenLabel Text="Identificador Constancia M S P" Component="IdentificadorConstanciaMSP" style="width: 100%" />
                </RadzenColumn>
                <RadzenColumn SizeMD="9">
                    <RadzenTextBox style="display: block; width: 100%" @bind-Value="@tramiteInfoadjuntatitulo.IdentificadorConstanciaMSP" Name="IdentificadorConstanciaMSP" />
                </RadzenColumn>
            </RadzenRow>
            <RadzenRow style="margin-bottom: 1rem">
                <RadzenColumn SizeMD="3">
                    <RadzenLabel Text="Tramite Info Adjunta Base" Component="TramiteInfoAdjuntaBase" style="width: 100%" />
                </RadzenColumn>
                <RadzenColumn SizeMD="9">
                    <RadzenDropDownDataGrid Data="@tramiteInfoadjuntabasesForOID" TextProperty="" ValueProperty="OID" AllowClear=true
                         Placeholder="Choose TramiteInfoAdjuntaBase" style="display: block; width: 100%" @bind-Value="@tramiteInfoadjuntatitulo.OID" Name="OID"
                        SelectedValue=@tramiteInfoadjuntabasesForOIDValue Count=@tramiteInfoadjuntabasesForOIDCount LoadData=@tramiteInfoadjuntabasesForOIDLoadData />
                </RadzenColumn>
            </RadzenRow>
            <RadzenRow style="margin-bottom: 1rem">
                <RadzenColumn SizeMD="3">
                    <RadzenLabel Text="Universidad Titulo Grado" Component="UniversidadTituloGrado" style="width: 100%" />
                </RadzenColumn>
                <RadzenColumn SizeMD="9">
                    <RadzenDropDownDataGrid Data="@universidadTituloGradosForUniversidad" TextProperty="Descripcion" ValueProperty="Id" AllowClear=true
                         Placeholder="Choose UniversidadTituloGrado" style="display: block; width: 100%" @bind-Value="@tramiteInfoadjuntatitulo.Universidad" Name="Universidad"
                        SelectedValue=@universidadTituloGradosForUniversidadValue Count=@universidadTituloGradosForUniversidadCount LoadData=@universidadTituloGradosForUniversidadLoadData />
                </RadzenColumn>
            </RadzenRow>
          <RadzenStack  Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" JustifyContent="JustifyContent.End" Gap="0.5rem">
                    <RadzenButton ButtonStyle="ButtonStyle.Primary" ButtonType="ButtonType.Submit" Icon="save" Text="Save" Variant="Variant.Flat" />
                    <RadzenButton ButtonStyle="ButtonStyle.Light" Text="Cancel" Variant="Variant.Flat" Click="@CancelButtonClick"  />
          </RadzenStack>
        </RadzenTemplateForm>
    </RadzenColumn>

