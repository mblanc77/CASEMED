@page "/sala-reserva-registros"

<PageTitle>SalaReservaRegistros</PageTitle>
<RadzenStack>
    <RadzenRow AlignItems="AlignItems.Center">
        <RadzenColumn Size="12" SizeMD="6">
            <RadzenText Text="SalaReservaRegistros" TextStyle="TextStyle.H3" TagName="TagName.H1" style="margin: 0" />
        </RadzenColumn>
        <RadzenColumn Size="12" SizeMD="6">
            <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" JustifyContent="JustifyContent.End" Gap="0.5rem">
                <RadzenSplitButton Icon="get_app" Text="Export" Click="@ExportClick" Variant="Variant.Flat" Shade="Shade.Lighter">
                    <RadzenSplitButtonItem Text="Excel" Value="xlsx" />
                    <RadzenSplitButtonItem Text="CSV" Value="csv" />
                </RadzenSplitButton>
                <RadzenButton Icon="add_circle_outline" Text="Add" Click="@AddButtonClick" Variant="Variant.Flat" />
            </RadzenStack>
        </RadzenColumn>
    </RadzenRow>
    <RadzenRow>
      <RadzenColumn SizeMD=12>
        <RadzenDataGrid @ref="grid0" ColumnWidth="200px"  AllowFiltering="true" FilterMode="FilterMode.Advanced" AllowPaging="true" AllowSorting="true" ShowPagingSummary="true" PageSizeOptions=@(new int[]{5, 10, 20, 30})
            Data="@salaReservaRegistros" Count=count LoadData=@Grid0LoadData  TItem="SGPA.Server.Models.CMU.SalaReservaRegistro" RowDoubleClick="@EditRow" >
            <Columns>
                <RadzenDataGridColumn TItem="SGPA.Server.Models.CMU.SalaReservaRegistro" Property="Id" Title="Id">
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="SGPA.Server.Models.CMU.SalaReservaRegistro" Property="Documento" Title="Documento">
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="SGPA.Server.Models.CMU.SalaReservaRegistro" Property="Telefono" Title="Telefono">
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="SGPA.Server.Models.CMU.SalaReservaRegistro" Property="EMail" Title="E Mail">
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="SGPA.Server.Models.CMU.SalaReservaRegistro" Property="Declaro1" Title="Declaro1">
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="SGPA.Server.Models.CMU.SalaReservaRegistro" Property="Declaro2" Title="Declaro2">
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="SGPA.Server.Models.CMU.SalaReservaRegistro" Property="Declaro3" Title="Declaro3">
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="SGPA.Server.Models.CMU.SalaReservaRegistro" Property="Estado" Title="Estado">
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="SGPA.Server.Models.CMU.SalaReservaRegistro" Property="FechaHoraIngreso" Title="Fecha Hora Ingreso">
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="SGPA.Server.Models.CMU.SalaReservaRegistro" Property="Nombre" Title="Nombre">
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="SGPA.Server.Models.CMU.SalaReservaRegistro" Property="FechaEnvioCorreo" Title="Fecha Envio Correo">
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="SGPA.Server.Models.CMU.SalaReservaRegistro" Property="OptimisticLockField" Title="Optimistic Lock Field">
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="SGPA.Server.Models.CMU.SalaReservaRegistro" Property="GCRecord" Title="G C Record">
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="SGPA.Server.Models.CMU.SalaReservaRegistro" Property="SalaReserva.NombreEvento" Title="Sala Reserva">
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="SGPA.Server.Models.CMU.SalaReservaRegistro" Filterable="false" Sortable="false" Width="70px" TextAlign="TextAlign.Center">
                    <Template Context="salaReservaRegistro">

                        <RadzenButton ButtonStyle="ButtonStyle.Danger" Icon="delete" Size="ButtonSize.Medium"
                            Shade="Shade.Lighter" Variant="Variant.Flat"
                            Click=@(args => GridDeleteButtonClick(args, salaReservaRegistro)) @onclick:stopPropagation="true" />
                    </Template>
                </RadzenDataGridColumn>
            </Columns>

        </RadzenDataGrid>

    </RadzenColumn>
  </RadzenRow>
</RadzenStack>
