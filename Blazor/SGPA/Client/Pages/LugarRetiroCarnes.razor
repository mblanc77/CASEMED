@page "/lugar-retiro-carnes"

<PageTitle>LugarRetiroCarnes</PageTitle>
<RadzenStack>
    <RadzenRow AlignItems="AlignItems.Center">
        <RadzenColumn Size="12" SizeMD="6">
            <RadzenText Text="LugarRetiroCarnes" TextStyle="TextStyle.H3" TagName="TagName.H1" style="margin: 0" />
        </RadzenColumn>
        <RadzenColumn Size="12" SizeMD="6">
            <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" JustifyContent="JustifyContent.End" Gap="0.5rem">
                <RadzenSplitButton Icon="get_app" Text="Export" Click="@ExportClick" Variant="Variant.Flat" Shade="Shade.Lighter">
                    <RadzenSplitButtonItem Text="Excel" Value="xlsx" />
                    <RadzenSplitButtonItem Text="CSV" Value="csv" />
                </RadzenSplitButton>
                <RadzenButton Icon="add_circle_outline" Text="Add" Click="@AddButtonClick" Variant="Variant.Flat" />
            </RadzenStack>
        </RadzenColumn>
    </RadzenRow>
    <RadzenRow>
      <RadzenColumn SizeMD=12>
        <RadzenDataGrid @ref="grid0" ColumnWidth="200px"  AllowFiltering="true" FilterMode="FilterMode.Advanced" AllowPaging="true" AllowSorting="true" ShowPagingSummary="true" PageSizeOptions=@(new int[]{5, 10, 20, 30})
            Data="@lugarRetiroCarnes" Count=count LoadData=@Grid0LoadData  TItem="SGPA.Server.Models.CMU.LugarRetiroCarne" RowDoubleClick="@EditRow" >
            <Columns>
                <RadzenDataGridColumn TItem="SGPA.Server.Models.CMU.LugarRetiroCarne" Property="Id" Title="Id">
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="SGPA.Server.Models.CMU.LugarRetiroCarne" Property="Descripcion" Title="Descripcion">
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="SGPA.Server.Models.CMU.LugarRetiroCarne" Property="Comentarios" Title="Comentarios">
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="SGPA.Server.Models.CMU.LugarRetiroCarne" Property="OptimisticLockField" Title="Optimistic Lock Field">
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="SGPA.Server.Models.CMU.LugarRetiroCarne" Property="GCRecord" Title="G C Record">
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="SGPA.Server.Models.CMU.LugarRetiroCarne" Property="Departamento1.Nombre" Title="Departamento1">
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="SGPA.Server.Models.CMU.LugarRetiroCarne" Property="GrupoLugarRetiroCarne.Descripcion" Title="Grupo Lugar Retiro Carne">
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="SGPA.Server.Models.CMU.LugarRetiroCarne" Filterable="false" Sortable="false" Width="70px" TextAlign="TextAlign.Center">
                    <Template Context="lugarRetiroCarne">

                        <RadzenButton ButtonStyle="ButtonStyle.Danger" Icon="delete" Size="ButtonSize.Medium"
                            Shade="Shade.Lighter" Variant="Variant.Flat"
                            Click=@(args => GridDeleteButtonClick(args, lugarRetiroCarne)) @onclick:stopPropagation="true" />
                    </Template>
                </RadzenDataGridColumn>
            </Columns>

        </RadzenDataGrid>

    </RadzenColumn>
  </RadzenRow>
</RadzenStack>
