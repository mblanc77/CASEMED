@page "/edit-rolroles-movimientotipomovimientostipo"

<PageTitle>Edit RolrolesMovimientotipomovimientostipo</PageTitle>
<RadzenRow>
    <RadzenColumn SizeMD="9">
    <RadzenLabel style="font-weight: bold" Text="Item no longer available." Visible="@(!canEdit)" />
    </RadzenColumn>
    <RadzenColumn SizeMD="3">
    <RadzenButton ButtonStyle="ButtonStyle.Secondary" style="margin-bottom: 20px" Text="Close" Visible="@(!canEdit)" Click="@CancelButtonClick" />
    </RadzenColumn>
</RadzenRow>
<RadzenRow>
    <RadzenColumn SizeMD="9">
    <RadzenLabel style="font-weight: bold" Text="Another user has made conflicting changes to one or more of the fields you have modified. Please reload." Visible="@hasChanges" />
    </RadzenColumn>
    <RadzenColumn SizeMD="3">
    <RadzenButton ButtonStyle="ButtonStyle.Secondary" Icon="autorenew" style="margin-bottom: 20px" Text="Reload" Visible="@hasChanges" Click="@ReloadButtonClick" />
    </RadzenColumn>
</RadzenRow>

    <RadzenColumn SizeMD=12>
        <RadzenAlert Shade="Shade.Lighter" Variant="Variant.Flat" Size="AlertSize.Small" AlertStyle="AlertStyle.Danger" Visible="@errorVisible">Cannot save RolrolesMovimientotipomovimientostipo</RadzenAlert>
        <RadzenTemplateForm TItem="SGPA.Server.Models.CMU.RolrolesMovimientotipomovimientostipo" Data="@rolrolesMovimientotipomovimientostipo" Visible="@(rolrolesMovimientotipomovimientostipo != null && canEdit)" Submit="@FormSubmit">
            <RadzenRow style="margin-bottom: 1rem">
                <RadzenColumn SizeMD="3">
                    <RadzenLabel Text="Optimistic Lock Field" Component="OptimisticLockField" style="width: 100%" />
                </RadzenColumn>
                <RadzenColumn SizeMD="9">
                    <RadzenNumeric style="display: block; width: 100%" @bind-Value="@rolrolesMovimientotipomovimientostipo.OptimisticLockField" Name="OptimisticLockField" />
                </RadzenColumn>
            </RadzenRow>
            <RadzenRow style="margin-bottom: 1rem">
                <RadzenColumn SizeMD="3">
                    <RadzenLabel Text="Movimiento Tipo" Component="MovimientoTipo" style="width: 100%" />
                </RadzenColumn>
                <RadzenColumn SizeMD="9">
                    <RadzenDropDownDataGrid Data="@movimientoTiposForMovimientosTipo" TextProperty="Descripcion" ValueProperty="Id" AllowClear=true
                         Placeholder="Choose MovimientoTipo" style="display: block; width: 100%" @bind-Value="@rolrolesMovimientotipomovimientostipo.MovimientosTipo" Name="MovimientosTipo"
                        SelectedValue=@movimientoTiposForMovimientosTipoValue Count=@movimientoTiposForMovimientosTipoCount LoadData=@movimientoTiposForMovimientosTipoLoadData />
                </RadzenColumn>
            </RadzenRow>
            <RadzenRow style="margin-bottom: 1rem">
                <RadzenColumn SizeMD="3">
                    <RadzenLabel Text="Rol" Component="Rol" style="width: 100%" />
                </RadzenColumn>
                <RadzenColumn SizeMD="9">
                    <RadzenDropDownDataGrid Data="@rolsForRoles" TextProperty="" ValueProperty="Oid" AllowClear=true
                         Placeholder="Choose Rol" style="display: block; width: 100%" @bind-Value="@rolrolesMovimientotipomovimientostipo.Roles" Name="Roles"
                        SelectedValue=@rolsForRolesValue Count=@rolsForRolesCount LoadData=@rolsForRolesLoadData />
                </RadzenColumn>
            </RadzenRow>
          <RadzenStack  Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" JustifyContent="JustifyContent.End" Gap="0.5rem">
                    <RadzenButton ButtonStyle="ButtonStyle.Primary" ButtonType="ButtonType.Submit" Icon="save" Text="Save" Variant="Variant.Flat" />
                    <RadzenButton ButtonStyle="ButtonStyle.Light" Text="Cancel" Variant="Variant.Flat" Click="@CancelButtonClick"  />
          </RadzenStack>
        </RadzenTemplateForm>
    </RadzenColumn>

