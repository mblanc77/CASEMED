@page "/add-rol"

<PageTitle>Add Rol</PageTitle>
    <RadzenColumn SizeMD=12>
        <RadzenAlert Shade="Shade.Lighter" Variant="Variant.Flat" Size="AlertSize.Small" AlertStyle="AlertStyle.Danger" Visible="@errorVisible">Cannot save Rol</RadzenAlert>
        <RadzenTemplateForm TItem="SGPA.Server.Models.CMU.Rol" Data="@rol" Visible="@(rol != null && canEdit)" Submit="@FormSubmit">
            <RadzenRow style="margin-bottom: 1rem">
                <RadzenColumn SizeMD="3">
                    <RadzenLabel Text="Security System Role" Component="SecuritySystemRole" style="width: 100%" />
                </RadzenColumn>
                <RadzenColumn SizeMD="9">
                    <RadzenDropDownDataGrid Data="@securitySystemRolesForOid" TextProperty="Name" ValueProperty="Oid" AllowClear=true
                         Placeholder="Choose SecuritySystemRole" style="display: block; width: 100%" @bind-Value="@rol.Oid" Name="Oid"
                        SelectedValue=@securitySystemRolesForOidValue Count=@securitySystemRolesForOidCount LoadData=@securitySystemRolesForOidLoadData />
                </RadzenColumn>
            </RadzenRow>
          <RadzenStack  Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" JustifyContent="JustifyContent.End" Gap="0.5rem">
                    <RadzenButton ButtonStyle="ButtonStyle.Primary" ButtonType="ButtonType.Submit" Icon="save" Text="Save" Variant="Variant.Flat" />
                    <RadzenButton ButtonStyle="ButtonStyle.Light" Text="Cancel" Variant="Variant.Flat" Click="@CancelButtonClick"  />
          </RadzenStack>
        </RadzenTemplateForm>
    </RadzenColumn>

