@page "/contactos"

<PageTitle>Contactos</PageTitle>
<RadzenStack>
    <RadzenRow AlignItems="AlignItems.Center">
        <RadzenColumn Size="12" SizeMD="6">
            <RadzenText Text="Contactos" TextStyle="TextStyle.H3" TagName="TagName.H1" style="margin: 0" />
        </RadzenColumn>
        <RadzenColumn Size="12" SizeMD="6">
            <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" JustifyContent="JustifyContent.End" Gap="0.5rem">
                <RadzenSplitButton Icon="get_app" Text="Export" Click="@ExportClick" Variant="Variant.Flat" Shade="Shade.Lighter">
                    <RadzenSplitButtonItem Text="Excel" Value="xlsx" />
                    <RadzenSplitButtonItem Text="CSV" Value="csv" />
                </RadzenSplitButton>
                <RadzenButton Icon="add_circle_outline" Text="Add" Click="@AddButtonClick" Variant="Variant.Flat" />
            </RadzenStack>
        </RadzenColumn>
    </RadzenRow>
    <RadzenRow>
      <RadzenColumn SizeMD=12>
        <RadzenDataGrid @ref="grid0" ColumnWidth="200px"  AllowFiltering="true" FilterMode="FilterMode.Advanced" AllowPaging="true" AllowSorting="true" ShowPagingSummary="true" PageSizeOptions=@(new int[]{5, 10, 20, 30})
            Data="@contactos" Count=count LoadData=@Grid0LoadData  TItem="SGPA.Server.Models.CMU.Contacto" RowDoubleClick="@EditRow" >
            <Columns>
                <RadzenDataGridColumn TItem="SGPA.Server.Models.CMU.Contacto" Property="Id" Title="Id">
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="SGPA.Server.Models.CMU.Contacto" Property="Nombres" Title="Nombres">
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="SGPA.Server.Models.CMU.Contacto" Property="PrimerApellido" Title="Primer Apellido">
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="SGPA.Server.Models.CMU.Contacto" Property="SegundoApellido" Title="Segundo Apellido">
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="SGPA.Server.Models.CMU.Contacto" Property="EMail" Title="E Mail">
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="SGPA.Server.Models.CMU.Contacto" Property="Telefono" Title="Telefono">
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="SGPA.Server.Models.CMU.Contacto" Property="Celular" Title="Celular">
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="SGPA.Server.Models.CMU.Contacto" Property="Denominacion" Title="Denominacion">
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="SGPA.Server.Models.CMU.Contacto" Property="NomComRazSoc" Title="Nom Com Raz Soc">
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="SGPA.Server.Models.CMU.Contacto" Property="Observaciones" Title="Observaciones">
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="SGPA.Server.Models.CMU.Contacto" Property="Direccion" Title="Direccion">
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="SGPA.Server.Models.CMU.Contacto" Property="OptimisticLockField" Title="Optimistic Lock Field">
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="SGPA.Server.Models.CMU.Contacto" Property="GCRecord" Title="G C Record">
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="SGPA.Server.Models.CMU.Contacto" Property="AreaContacto.Descripcion" Title="Area Contacto">
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="SGPA.Server.Models.CMU.Contacto" Property="CargoContacto.Descripcion" Title="Cargo Contacto">
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="SGPA.Server.Models.CMU.Contacto" Property="GrupoContacto.Descripcion" Title="Grupo Contacto">
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="SGPA.Server.Models.CMU.Contacto" Filterable="false" Sortable="false" Width="70px" TextAlign="TextAlign.Center">
                    <Template Context="contacto">

                        <RadzenButton ButtonStyle="ButtonStyle.Danger" Icon="delete" Size="ButtonSize.Medium"
                            Shade="Shade.Lighter" Variant="Variant.Flat"
                            Click=@(args => GridDeleteButtonClick(args, contacto)) @onclick:stopPropagation="true" />
                    </Template>
                </RadzenDataGridColumn>
            </Columns>

        </RadzenDataGrid>

    </RadzenColumn>
  </RadzenRow>
</RadzenStack>
