@page "/add-colegiado-declaracion-juradum"

<PageTitle>Add ColegiadoDeclaracionJuradum</PageTitle>
    <RadzenColumn SizeMD=12>
        <RadzenAlert Shade="Shade.Lighter" Variant="Variant.Flat" Size="AlertSize.Small" AlertStyle="AlertStyle.Danger" Visible="@errorVisible">Cannot save ColegiadoDeclaracionJuradum</RadzenAlert>
        <RadzenTemplateForm TItem="SGPA.Server.Models.CMU.ColegiadoDeclaracionJuradum" Data="@colegiadoDeclaracionJuradum" Visible="@(colegiadoDeclaracionJuradum != null && canEdit)" Submit="@FormSubmit">
            <RadzenRow style="margin-bottom: 1rem">
                <RadzenColumn SizeMD="3">
                    <RadzenLabel Text="Fecha" Component="Fecha" style="width: 100%" />
                </RadzenColumn>
                <RadzenColumn SizeMD="9">
                    <RadzenDatePicker DateFormat="MM/dd/yyyy" style="display: block; width: 100%" @bind-Value="@colegiadoDeclaracionJuradum.Fecha" Name="Fecha" />
                </RadzenColumn>
            </RadzenRow>
            <RadzenRow style="margin-bottom: 1rem">
                <RadzenColumn SizeMD="3">
                    <RadzenLabel Text="Monto Nominal D J" Component="MontoNominalDJ" style="width: 100%" />
                </RadzenColumn>
                <RadzenColumn SizeMD="9">
                    <RadzenNumeric style="display: block; width: 100%" @bind-Value="@colegiadoDeclaracionJuradum.MontoNominalDJ" Name="MontoNominalDJ" />
                </RadzenColumn>
            </RadzenRow>
            <RadzenRow style="margin-bottom: 1rem">
                <RadzenColumn SizeMD="3">
                    <RadzenLabel Text="Comentario" Component="Comentario" style="width: 100%" />
                </RadzenColumn>
                <RadzenColumn SizeMD="9">
                    <RadzenTextBox style="display: block; width: 100%" @bind-Value="@colegiadoDeclaracionJuradum.Comentario" Name="Comentario" />
                </RadzenColumn>
            </RadzenRow>
            <RadzenRow style="margin-bottom: 1rem">
                <RadzenColumn SizeMD="3">
                    <RadzenLabel Text="Nro Formulario" Component="NroFormulario" style="width: 100%" />
                </RadzenColumn>
                <RadzenColumn SizeMD="9">
                    <RadzenNumeric style="display: block; width: 100%" @bind-Value="@colegiadoDeclaracionJuradum.NroFormulario" Name="NroFormulario" />
                </RadzenColumn>
            </RadzenRow>
            <RadzenRow style="margin-bottom: 1rem">
                <RadzenColumn SizeMD="3">
                    <RadzenLabel Text="Fecha Vencimiento" Component="FechaVencimiento" style="width: 100%" />
                </RadzenColumn>
                <RadzenColumn SizeMD="9">
                    <RadzenDatePicker DateFormat="MM/dd/yyyy" style="display: block; width: 100%" @bind-Value="@colegiadoDeclaracionJuradum.FechaVencimiento" Name="FechaVencimiento" />
                </RadzenColumn>
            </RadzenRow>
            <RadzenRow style="margin-bottom: 1rem">
                <RadzenColumn SizeMD="3">
                    <RadzenLabel Text="Fecha Verificacion" Component="FechaVerificacion" style="width: 100%" />
                </RadzenColumn>
                <RadzenColumn SizeMD="9">
                    <RadzenDatePicker DateFormat="MM/dd/yyyy" style="display: block; width: 100%" @bind-Value="@colegiadoDeclaracionJuradum.FechaVerificacion" Name="FechaVerificacion" />
                </RadzenColumn>
            </RadzenRow>
            <RadzenRow style="margin-bottom: 1rem">
                <RadzenColumn SizeMD="3">
                    <RadzenLabel Text="Fecha Envio Notificacion Vencimiento" Component="FechaEnvioNotificacionVencimiento" style="width: 100%" />
                </RadzenColumn>
                <RadzenColumn SizeMD="9">
                    <RadzenDatePicker DateFormat="MM/dd/yyyy" style="display: block; width: 100%" @bind-Value="@colegiadoDeclaracionJuradum.FechaEnvioNotificacionVencimiento" Name="FechaEnvioNotificacionVencimiento" />
                </RadzenColumn>
            </RadzenRow>
            <RadzenRow style="margin-bottom: 1rem">
                <RadzenColumn SizeMD="3">
                    <RadzenLabel Text="Fecha Procesamiento Vencimiento" Component="FechaProcesamientoVencimiento" style="width: 100%" />
                </RadzenColumn>
                <RadzenColumn SizeMD="9">
                    <RadzenDatePicker DateFormat="MM/dd/yyyy" style="display: block; width: 100%" @bind-Value="@colegiadoDeclaracionJuradum.FechaProcesamientoVencimiento" Name="FechaProcesamientoVencimiento" />
                </RadzenColumn>
            </RadzenRow>
            <RadzenRow style="margin-bottom: 1rem">
                <RadzenColumn SizeMD="3">
                    <RadzenLabel Text="Excluir Filtro Vencimiento" Component="ExcluirFiltroVencimiento" style="width: 100%" />
                </RadzenColumn>
                <RadzenColumn SizeMD="9">
                    <RadzenCheckBox @bind-Value="@colegiadoDeclaracionJuradum.ExcluirFiltroVencimiento" Name="ExcluirFiltroVencimiento" />
                </RadzenColumn>
            </RadzenRow>
            <RadzenRow style="margin-bottom: 1rem">
                <RadzenColumn SizeMD="3">
                    <RadzenLabel Text="Fecha Presentacion" Component="FechaPresentacion" style="width: 100%" />
                </RadzenColumn>
                <RadzenColumn SizeMD="9">
                    <RadzenDatePicker DateFormat="MM/dd/yyyy" style="display: block; width: 100%" @bind-Value="@colegiadoDeclaracionJuradum.FechaPresentacion" Name="FechaPresentacion" />
                </RadzenColumn>
            </RadzenRow>
            <RadzenRow style="margin-bottom: 1rem">
                <RadzenColumn SizeMD="3">
                    <RadzenLabel Text="Optimistic Lock Field" Component="OptimisticLockField" style="width: 100%" />
                </RadzenColumn>
                <RadzenColumn SizeMD="9">
                    <RadzenNumeric style="display: block; width: 100%" @bind-Value="@colegiadoDeclaracionJuradum.OptimisticLockField" Name="OptimisticLockField" />
                </RadzenColumn>
            </RadzenRow>
            <RadzenRow style="margin-bottom: 1rem">
                <RadzenColumn SizeMD="3">
                    <RadzenLabel Text="G C Record" Component="GCRecord" style="width: 100%" />
                </RadzenColumn>
                <RadzenColumn SizeMD="9">
                    <RadzenNumeric style="display: block; width: 100%" @bind-Value="@colegiadoDeclaracionJuradum.GCRecord" Name="GCRecord" />
                </RadzenColumn>
            </RadzenRow>
            <RadzenRow style="margin-bottom: 1rem">
                <RadzenColumn SizeMD="3">
                    <RadzenLabel Text="Anulada" Component="Anulada" style="width: 100%" />
                </RadzenColumn>
                <RadzenColumn SizeMD="9">
                    <RadzenCheckBox @bind-Value="@colegiadoDeclaracionJuradum.Anulada" Name="Anulada" />
                </RadzenColumn>
            </RadzenRow>
            <RadzenRow style="margin-bottom: 1rem">
                <RadzenColumn SizeMD="3">
                    <RadzenLabel Text="Fecha Anulada" Component="FechaAnulada" style="width: 100%" />
                </RadzenColumn>
                <RadzenColumn SizeMD="9">
                    <RadzenDatePicker DateFormat="MM/dd/yyyy" style="display: block; width: 100%" @bind-Value="@colegiadoDeclaracionJuradum.FechaAnulada" Name="FechaAnulada" />
                </RadzenColumn>
            </RadzenRow>
            <RadzenRow style="margin-bottom: 1rem">
                <RadzenColumn SizeMD="3">
                    <RadzenLabel Text="Fecha Ingreso" Component="FechaIngreso" style="width: 100%" />
                </RadzenColumn>
                <RadzenColumn SizeMD="9">
                    <RadzenDatePicker DateFormat="MM/dd/yyyy" style="display: block; width: 100%" @bind-Value="@colegiadoDeclaracionJuradum.FechaIngreso" Name="FechaIngreso" />
                </RadzenColumn>
            </RadzenRow>
            <RadzenRow style="margin-bottom: 1rem">
                <RadzenColumn SizeMD="3">
                    <RadzenLabel Text="Origen" Component="Origen" style="width: 100%" />
                </RadzenColumn>
                <RadzenColumn SizeMD="9">
                    <RadzenNumeric style="display: block; width: 100%" @bind-Value="@colegiadoDeclaracionJuradum.Origen" Name="Origen" />
                </RadzenColumn>
            </RadzenRow>
            <RadzenRow style="margin-bottom: 1rem">
                <RadzenColumn SizeMD="3">
                    <RadzenLabel Text="Cedula" Component="Cedula" style="width: 100%" />
                </RadzenColumn>
                <RadzenColumn SizeMD="9">
                    <RadzenNumeric style="display: block; width: 100%" @bind-Value="@colegiadoDeclaracionJuradum.Cedula" Name="Cedula" />
                </RadzenColumn>
            </RadzenRow>
            <RadzenRow style="margin-bottom: 1rem">
                <RadzenColumn SizeMD="3">
                    <RadzenLabel Text="Fecha Nacimiento" Component="FechaNacimiento" style="width: 100%" />
                </RadzenColumn>
                <RadzenColumn SizeMD="9">
                    <RadzenDatePicker DateFormat="MM/dd/yyyy" style="display: block; width: 100%" @bind-Value="@colegiadoDeclaracionJuradum.FechaNacimiento" Name="FechaNacimiento" />
                </RadzenColumn>
            </RadzenRow>
            <RadzenRow style="margin-bottom: 1rem">
                <RadzenColumn SizeMD="3">
                    <RadzenLabel Text="Motivo Otros Inactividad" Component="MotivoOtrosInactividad" style="width: 100%" />
                </RadzenColumn>
                <RadzenColumn SizeMD="9">
                    <RadzenTextBox style="display: block; width: 100%" @bind-Value="@colegiadoDeclaracionJuradum.MotivoOtrosInactividad" Name="MotivoOtrosInactividad" />
                </RadzenColumn>
            </RadzenRow>
            <RadzenRow style="margin-bottom: 1rem">
                <RadzenColumn SizeMD="3">
                    <RadzenLabel Text="Colegiado1" Component="Colegiado1" style="width: 100%" />
                </RadzenColumn>
                <RadzenColumn SizeMD="9">
                    <RadzenDropDownDataGrid Data="@colegiadosForColegiado" TextProperty="Nombres" ValueProperty="Documento" AllowClear=true
                         Placeholder="Choose Colegiado1" style="display: block; width: 100%" @bind-Value="@colegiadoDeclaracionJuradum.Colegiado" Name="Colegiado"
                        SelectedValue=@colegiadosForColegiadoValue Count=@colegiadosForColegiadoCount LoadData=@colegiadosForColegiadoLoadData />
                </RadzenColumn>
            </RadzenRow>
            <RadzenRow style="margin-bottom: 1rem">
                <RadzenColumn SizeMD="3">
                    <RadzenLabel Text="Djinactividad Motivo" Component="DjinactividadMotivo" style="width: 100%" />
                </RadzenColumn>
                <RadzenColumn SizeMD="9">
                    <RadzenDropDownDataGrid Data="@djInactividadMotivosForMotivoInactividad" TextProperty="Descripcion" ValueProperty="Id" AllowClear=true
                         Placeholder="Choose DjinactividadMotivo" style="display: block; width: 100%" @bind-Value="@colegiadoDeclaracionJuradum.MotivoInactividad" Name="MotivoInactividad"
                        SelectedValue=@djInactividadMotivosForMotivoInactividadValue Count=@djInactividadMotivosForMotivoInactividadCount LoadData=@djInactividadMotivosForMotivoInactividadLoadData />
                </RadzenColumn>
            </RadzenRow>
            <RadzenRow style="margin-bottom: 1rem">
                <RadzenColumn SizeMD="3">
                    <RadzenLabel Text="Xpobject Type" Component="XpobjectType" style="width: 100%" />
                </RadzenColumn>
                <RadzenColumn SizeMD="9">
                    <RadzenDropDownDataGrid Data="@xpObjectTypesForObjectType" TextProperty="TypeName" ValueProperty="OID" AllowClear=true
                         Placeholder="Choose XpobjectType" style="display: block; width: 100%" @bind-Value="@colegiadoDeclaracionJuradum.ObjectType" Name="ObjectType"
                        SelectedValue=@xpObjectTypesForObjectTypeValue Count=@xpObjectTypesForObjectTypeCount LoadData=@xpObjectTypesForObjectTypeLoadData />
                </RadzenColumn>
            </RadzenRow>
            <RadzenRow style="margin-bottom: 1rem">
                <RadzenColumn SizeMD="3">
                    <RadzenLabel Text="Declaracion Jurada Tipo" Component="DeclaracionJuradaTipo" style="width: 100%" />
                </RadzenColumn>
                <RadzenColumn SizeMD="9">
                    <RadzenDropDownDataGrid Data="@declaracionJuradaTiposForTipo" TextProperty="Descripcion" ValueProperty="Id" AllowClear=true
                         Placeholder="Choose DeclaracionJuradaTipo" style="display: block; width: 100%" @bind-Value="@colegiadoDeclaracionJuradum.Tipo" Name="Tipo"
                        SelectedValue=@declaracionJuradaTiposForTipoValue Count=@declaracionJuradaTiposForTipoCount LoadData=@declaracionJuradaTiposForTipoLoadData />
                </RadzenColumn>
            </RadzenRow>
          <RadzenStack  Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" JustifyContent="JustifyContent.End" Gap="0.5rem">
                    <RadzenButton ButtonStyle="ButtonStyle.Primary" ButtonType="ButtonType.Submit" Icon="save" Text="Save" Variant="Variant.Flat" />
                    <RadzenButton ButtonStyle="ButtonStyle.Light" Text="Cancel" Variant="Variant.Flat" Click="@CancelButtonClick"  />
          </RadzenStack>
        </RadzenTemplateForm>
    </RadzenColumn>

