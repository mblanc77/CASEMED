@page "/add-convenio-financiacion"

<PageTitle>Add ConvenioFinanciacion</PageTitle>
    <RadzenColumn SizeMD=12>
        <RadzenAlert Shade="Shade.Lighter" Variant="Variant.Flat" Size="AlertSize.Small" AlertStyle="AlertStyle.Danger" Visible="@errorVisible">Cannot save ConvenioFinanciacion</RadzenAlert>
        <RadzenTemplateForm TItem="SGPA.Server.Models.CMU.ConvenioFinanciacion" Data="@convenioFinanciacion" Visible="@(convenioFinanciacion != null && canEdit)" Submit="@FormSubmit">
            <RadzenRow style="margin-bottom: 1rem">
                <RadzenColumn SizeMD="3">
                    <RadzenLabel Text="Importe Financiar" Component="ImporteFinanciar" style="width: 100%" />
                </RadzenColumn>
                <RadzenColumn SizeMD="9">
                    <RadzenNumeric style="display: block; width: 100%" @bind-Value="@convenioFinanciacion.ImporteFinanciar" Name="ImporteFinanciar" />
                </RadzenColumn>
            </RadzenRow>
            <RadzenRow style="margin-bottom: 1rem">
                <RadzenColumn SizeMD="3">
                    <RadzenLabel Text="Cuotas" Component="Cuotas" style="width: 100%" />
                </RadzenColumn>
                <RadzenColumn SizeMD="9">
                    <RadzenNumeric style="display: block; width: 100%" @bind-Value="@convenioFinanciacion.Cuotas" Name="Cuotas" />
                </RadzenColumn>
            </RadzenRow>
            <RadzenRow style="margin-bottom: 1rem">
                <RadzenColumn SizeMD="3">
                    <RadzenLabel Text="Convenio" Component="Convenio" style="width: 100%" />
                </RadzenColumn>
                <RadzenColumn SizeMD="9">
                    <RadzenDropDownDataGrid Data="@conveniosForId" TextProperty="MotivoAnulado" ValueProperty="Id" AllowClear=true
                         Placeholder="Choose Convenio" style="display: block; width: 100%" @bind-Value="@convenioFinanciacion.Id" Name="Id"
                        SelectedValue=@conveniosForIdValue Count=@conveniosForIdCount LoadData=@conveniosForIdLoadData />
                </RadzenColumn>
            </RadzenRow>
          <RadzenStack  Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" JustifyContent="JustifyContent.End" Gap="0.5rem">
                    <RadzenButton ButtonStyle="ButtonStyle.Primary" ButtonType="ButtonType.Submit" Icon="save" Text="Save" Variant="Variant.Flat" />
                    <RadzenButton ButtonStyle="ButtonStyle.Light" Text="Cancel" Variant="Variant.Flat" Click="@CancelButtonClick"  />
          </RadzenStack>
        </RadzenTemplateForm>
    </RadzenColumn>

