@page "/agente-cobranzas"

<PageTitle>AgenteCobranzas</PageTitle>
<RadzenStack>
    <RadzenRow AlignItems="AlignItems.Center">
        <RadzenColumn Size="12" SizeMD="6">
            <RadzenText Text="AgenteCobranzas" TextStyle="TextStyle.H3" TagName="TagName.H1" style="margin: 0" />
        </RadzenColumn>
        <RadzenColumn Size="12" SizeMD="6">
            <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" JustifyContent="JustifyContent.End" Gap="0.5rem">
                <RadzenSplitButton Icon="get_app" Text="Export" Click="@ExportClick" Variant="Variant.Flat" Shade="Shade.Lighter">
                    <RadzenSplitButtonItem Text="Excel" Value="xlsx" />
                    <RadzenSplitButtonItem Text="CSV" Value="csv" />
                </RadzenSplitButton>
                <RadzenButton Icon="add_circle_outline" Text="Add" Click="@AddButtonClick" Variant="Variant.Flat" />
            </RadzenStack>
        </RadzenColumn>
    </RadzenRow>
    <RadzenRow>
      <RadzenColumn SizeMD=12>
        <RadzenDataGrid @ref="grid0" ColumnWidth="200px"  AllowFiltering="true" FilterMode="FilterMode.Advanced" AllowPaging="true" AllowSorting="true" ShowPagingSummary="true" PageSizeOptions=@(new int[]{5, 10, 20, 30})
            Data="@agenteCobranzas" Count=count LoadData=@Grid0LoadData  TItem="SGPA.Server.Models.CMU.AgenteCobranza" RowDoubleClick="@EditRow" >
            <Columns>
                <RadzenDataGridColumn TItem="SGPA.Server.Models.CMU.AgenteCobranza" Property="ParseClass" Title="Parse Class">
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="SGPA.Server.Models.CMU.AgenteCobranza" Property="NombreContacto" Title="Nombre Contacto">
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="SGPA.Server.Models.CMU.AgenteCobranza" Property="TelefonoContacto" Title="Telefono Contacto">
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="SGPA.Server.Models.CMU.AgenteCobranza" Property="EMailContacto" Title="E Mail Contacto">
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="SGPA.Server.Models.CMU.AgenteCobranza" Property="SobrescribeEnColegiadoDesdeDeposito" Title="Sobrescribe En Colegiado Desde Deposito">
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="SGPA.Server.Models.CMU.AgenteCobranza" Property="IdExterno" Title="Id Externo">
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="SGPA.Server.Models.CMU.AgenteCobranza" Property="AgenteCobranzaTipo.Descripcion" Title="Agente Cobranza Tipo">
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="SGPA.Server.Models.CMU.AgenteCobranza" Property="CuentaBancarium" Title="Cuenta Bancarium">
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="SGPA.Server.Models.CMU.AgenteCobranza" Property="Departamento1.Nombre" Title="Departamento1">
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="SGPA.Server.Models.CMU.AgenteCobranza" Property="AgenteGrupo.Descripcion" Title="Agente Grupo">
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="SGPA.Server.Models.CMU.AgenteCobranza" Property="OrigenMovimiento.Descripcion" Title="Origen Movimiento">
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="SGPA.Server.Models.CMU.AgenteCobranza" Property="Region1.Descripcion" Title="Region1">
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="SGPA.Server.Models.CMU.AgenteCobranza" Filterable="false" Sortable="false" Width="70px" TextAlign="TextAlign.Center">
                    <Template Context="agenteCobranza">

                        <RadzenButton ButtonStyle="ButtonStyle.Danger" Icon="delete" Size="ButtonSize.Medium"
                            Shade="Shade.Lighter" Variant="Variant.Flat"
                            Click=@(args => GridDeleteButtonClick(args, agenteCobranza)) @onclick:stopPropagation="true" />
                    </Template>
                </RadzenDataGridColumn>
            </Columns>

        </RadzenDataGrid>

    </RadzenColumn>
  </RadzenRow>
</RadzenStack>
