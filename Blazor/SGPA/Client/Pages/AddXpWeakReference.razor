@page "/add-xp-weak-reference"

<PageTitle>Add XpWeakReference</PageTitle>
    <RadzenColumn SizeMD=12>
        <RadzenAlert Shade="Shade.Lighter" Variant="Variant.Flat" Size="AlertSize.Small" AlertStyle="AlertStyle.Danger" Visible="@errorVisible">Cannot save XpWeakReference</RadzenAlert>
        <RadzenTemplateForm TItem="SGPA.Server.Models.CMU.XpWeakReference" Data="@xpWeakReference" Visible="@(xpWeakReference != null && canEdit)" Submit="@FormSubmit">
            <RadzenRow style="margin-bottom: 1rem">
                <RadzenColumn SizeMD="3">
                    <RadzenLabel Text="Target Key" Component="TargetKey" style="width: 100%" />
                </RadzenColumn>
                <RadzenColumn SizeMD="9">
                    <RadzenTextBox style="display: block; width: 100%" @bind-Value="@xpWeakReference.TargetKey" Name="TargetKey" />
                </RadzenColumn>
            </RadzenRow>
            <RadzenRow style="margin-bottom: 1rem">
                <RadzenColumn SizeMD="3">
                    <RadzenLabel Text="Optimistic Lock Field" Component="OptimisticLockField" style="width: 100%" />
                </RadzenColumn>
                <RadzenColumn SizeMD="9">
                    <RadzenNumeric style="display: block; width: 100%" @bind-Value="@xpWeakReference.OptimisticLockField" Name="OptimisticLockField" />
                </RadzenColumn>
            </RadzenRow>
            <RadzenRow style="margin-bottom: 1rem">
                <RadzenColumn SizeMD="3">
                    <RadzenLabel Text="G C Record" Component="GCRecord" style="width: 100%" />
                </RadzenColumn>
                <RadzenColumn SizeMD="9">
                    <RadzenNumeric style="display: block; width: 100%" @bind-Value="@xpWeakReference.GCRecord" Name="GCRecord" />
                </RadzenColumn>
            </RadzenRow>
            <RadzenRow style="margin-bottom: 1rem">
                <RadzenColumn SizeMD="3">
                    <RadzenLabel Text="Xpobject Type" Component="XpobjectType" style="width: 100%" />
                </RadzenColumn>
                <RadzenColumn SizeMD="9">
                    <RadzenDropDownDataGrid Data="@xpObjectTypesForObjectType" TextProperty="TypeName" ValueProperty="OID" AllowClear=true
                         Placeholder="Choose XpobjectType" style="display: block; width: 100%" @bind-Value="@xpWeakReference.ObjectType" Name="ObjectType"
                        SelectedValue=@xpObjectTypesForObjectTypeValue Count=@xpObjectTypesForObjectTypeCount LoadData=@xpObjectTypesForObjectTypeLoadData />
                </RadzenColumn>
            </RadzenRow>
            <RadzenRow style="margin-bottom: 1rem">
                <RadzenColumn SizeMD="3">
                    <RadzenLabel Text="Xpobject Type1" Component="XpobjectType1" style="width: 100%" />
                </RadzenColumn>
                <RadzenColumn SizeMD="9">
                    <RadzenDropDownDataGrid Data="@xpObjectTypesForTargetType" TextProperty="TypeName" ValueProperty="OID" AllowClear=true
                         Placeholder="Choose XpobjectType1" style="display: block; width: 100%" @bind-Value="@xpWeakReference.TargetType" Name="TargetType"
                        SelectedValue=@xpObjectTypesForTargetTypeValue Count=@xpObjectTypesForTargetTypeCount LoadData=@xpObjectTypesForTargetTypeLoadData />
                </RadzenColumn>
            </RadzenRow>
          <RadzenStack  Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" JustifyContent="JustifyContent.End" Gap="0.5rem">
                    <RadzenButton ButtonStyle="ButtonStyle.Primary" ButtonType="ButtonType.Submit" Icon="save" Text="Save" Variant="Variant.Flat" />
                    <RadzenButton ButtonStyle="ButtonStyle.Light" Text="Cancel" Variant="Variant.Flat" Click="@CancelButtonClick"  />
          </RadzenStack>
        </RadzenTemplateForm>
    </RadzenColumn>

