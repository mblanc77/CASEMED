<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
    <!-- Feed offline del install local de DevExpress (paquetes licenciados pre-release 25.2.6-pre-26075).
         Trae DLLs + static web assets + dependencias transitivas, a diferencia de referenciar DLLs sueltas. -->
    <add key="DevExpress-Local" value="C:\Program Files\DevExpress 25.2\Components\System\Components\packages" />
  </packageSources>
</configuration>
