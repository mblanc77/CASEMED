@* Guard global de "cambios sin guardar". Isla interactiva (va en MainLayout). No renderiza nada: su única tarea
   es reflejar el estado de UnsavedChangesService (scoped, compartido por el circuito) en el flag de documento
   window.sgpaUnsaved, que el listener JS de App.razor usa para advertir antes de navegar/recargar. Se hace por JS
   (y no con NavigationLock) porque el Router del proyecto es estático: la navegación interna va por enhanced nav y
   NavigationLock no la intercepta. *@
@using Sgpa.Web.State
@implements IDisposable
@inject UnsavedChangesService Unsaved
@inject IJSRuntime JS

@code {
    protected override void OnInitialized() => Unsaved.Changed += OnChanged;

    private void OnChanged() => InvokeAsync(StateHasChanged);

    // En cada render empuja el estado actual al flag de documento (idempotente). El try/catch cubre el prerender,
    // donde el interop JS todavía no está disponible.
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        try { await JS.InvokeVoidAsync("sgpaSetUnsaved", Unsaved.HasUnsavedChanges); }
        catch { /* interop aún no disponible (prerender) */ }
    }

    public void Dispose() => Unsaved.Changed -= OnChanged;
}
