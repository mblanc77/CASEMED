<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="/" />
    @* Tema DevExpress blazing-berry recoloreado a la marca (primario #1C3680) — ver wwwroot/css/sgpa-theme.css *@
    <link rel="stylesheet" href="css/sgpa-theme.css" />
    @* DevExpress Reporting (visor/diseñador): CSS cableado a mano desde el install local (no NuGet). *@
    <link rel="stylesheet" href="_content/DevExpress.Blazor.Viewer/css/dx-blazor-viewer-components.bs5.css" />
    <link rel="stylesheet" href="_content/DevExpress.Blazor.Reporting.Viewer/css/dx-blazor-reporting-components.bs5.css" />
    <link rel="stylesheet" href="lib/fontawesome/css/all.min.css" />
    <link rel="stylesheet" href="@Assets["app.css"]" />
    <link rel="stylesheet" href="@Assets["Sgpa.Web.styles.css"]" />
    <ImportMap />
    @* Favicon CASEMED (logo "Short"): SVG vectorial para navegadores modernos, ICO multi-resolución y PNG de respaldo *@
    <link rel="icon" type="image/svg+xml" href="favicon.svg" />
    <link rel="icon" type="image/x-icon" href="favicon.ico" />
    <link rel="icon" type="image/png" sizes="32x32" href="favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="favicon-16x16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="apple-touch-icon.png" />
    <HeadOutlet />
</head>

<body>
    <Routes />
    @* Guard de "cambios sin guardar" a nivel documento. Va ANTES de blazor.web.js para registrar el listener de
       clics en fase de captura antes que la navegación mejorada (enhanced nav) del Router estático, donde
       NavigationLock no intercepta. Blazor sólo togglea el flag vía window.sgpaSetUnsaved (ver UnsavedChangesGuard). *@
    <script>
        window.sgpaUnsaved = { dirty: false, msg: 'Tenés cambios sin guardar. Si salís de la página se van a perder.' };
        window.sgpaSetUnsaved = function (v) { window.sgpaUnsaved.dirty = !!v; };
        // Confirma salir si hay cambios sin guardar; al aceptar baja el flag (lo usa el listener de clics y sgpaGoBack).
        window.sgpaConfirmLeave = function () {
            if (!window.sgpaUnsaved.dirty) return true;
            if (window.confirm(window.sgpaUnsaved.msg)) { window.sgpaUnsaved.dirty = false; return true; }
            return false;
        };
        (function () {
            // F1 es el atajo de "buscar afiliado" en los campos FK de cédula. Suprimimos la ayuda del navegador
            // (que F1 abre por defecto) en fase de captura; el evento igual llega al handler keydown de Blazor.
            document.addEventListener('keydown', function (e) {
                if (e.key === 'F1') e.preventDefault();
            }, true);

            // --- Atajos de teclado de las vistas CRUD (SgpaCrudView) ---
            // Cada vista CRUD activa se registra acá; el último registrado (tope de la pila) recibe el atajo. Se
            // bloquea el default del navegador SOLO para los chords que mapeamos; Supr/F2 se ignoran si el foco
            // está en un campo editable (para no romper la edición de texto). El esquema evita choques con el
            // navegador: Alt+N nuevo, Ctrl+S guardar, Supr eliminar, F2 editar, Alt+R refrescar, Ctrl+B buscar.
            window.sgpaShortcutHandlers = window.sgpaShortcutHandlers || [];
            window.sgpaRegisterShortcuts = function (ref) { window.sgpaShortcutHandlers.push(ref); };
            window.sgpaUnregisterShortcuts = function (ref) {
                var i = window.sgpaShortcutHandlers.indexOf(ref);
                if (i >= 0) window.sgpaShortcutHandlers.splice(i, 1);
            };
            function sgpaIsEditable(el) {
                if (!el) return false;
                var tag = el.tagName;
                return tag === 'INPUT' || tag === 'TEXTAREA' || tag === 'SELECT' || el.isContentEditable === true;
            }
            document.addEventListener('keydown', function (e) {
                if (e.repeat) return;
                var handlers = window.sgpaShortcutHandlers;
                if (!handlers.length) return;
                var action = null, needsNoEdit = false;
                var k = (e.key || '').toLowerCase();
                if (e.altKey && !e.ctrlKey && !e.metaKey && k === 'n') action = 'new';
                else if (e.ctrlKey && !e.altKey && !e.metaKey && k === 's') action = 'save';
                else if (e.altKey && !e.ctrlKey && !e.metaKey && k === 'r') action = 'refresh';
                else if (e.ctrlKey && !e.altKey && !e.metaKey && k === 'b') action = 'search';
                else if (!e.ctrlKey && !e.altKey && !e.metaKey && e.key === 'F2') { action = 'edit'; needsNoEdit = true; }
                else if (!e.ctrlKey && !e.altKey && !e.metaKey && (e.key === 'Delete' || e.key === 'Del')) { action = 'delete'; needsNoEdit = true; }
                if (!action) return;
                if (needsNoEdit && sgpaIsEditable(document.activeElement)) return;
                e.preventDefault();
                e.stopPropagation();
                handlers[handlers.length - 1].invokeMethodAsync('HandleShortcutAsync', action);
            }, true);
            // Recarga / cierre de pestaña / navegación externa o full-page.
            window.addEventListener('beforeunload', function (e) {
                if (window.sgpaUnsaved.dirty) { e.preventDefault(); e.returnValue = ''; }
            });
            // Navegación interna (clic en un <a> → enhanced nav). Captura para poder cancelar antes que Blazor.
            document.addEventListener('click', function (e) {
                if (!window.sgpaUnsaved.dirty || e.defaultPrevented || e.button !== 0
                    || e.ctrlKey || e.metaKey || e.shiftKey || e.altKey) return;
                var a = e.target.closest ? e.target.closest('a[href]') : null;
                if (!a || a.target === '_blank' || a.hasAttribute('download')) return;
                var raw = a.getAttribute('href');
                if (raw && (raw.charAt(0) === '#' || raw.toLowerCase().indexOf('javascript:') === 0)) return;
                var url = new URL(a.href, window.location.href);          // a.href resuelve href="" a la URL actual
                if (url.origin !== window.location.origin) return;        // externo → lo cubre beforeunload
                if (url.pathname === window.location.pathname && url.search === window.location.search) return;
                if (!window.sgpaConfirmLeave()) { e.preventDefault(); e.stopImmediatePropagation(); }
            }, true);
        })();
    </script>
    <script src="_framework/blazor.web.js"></script>
    <script>
        // "Volver" inteligente: si hay historial de navegación, vuelve a la página ANTERIOR (no a una ruta fija);
        // si no hay (deep-link / primera carga), navega a la ruta de fallback. Reemplaza los NavigateTo fijos.
        window.sgpaGoBack = (fallbackUrl) => {
            if (!window.sgpaConfirmLeave || window.sgpaConfirmLeave()) {
                if (window.history.length > 1) { window.history.back(); }
                else if (fallbackUrl) { window.location.assign(fallbackUrl); }
            }
        };
        window.sgpaDownloadText = (fileName, content) => {
            const blob = new Blob([content], { type: 'text/plain' });
            const url = URL.createObjectURL(blob);
            const a = document.createElement('a');
            a.href = url; a.download = fileName;
            document.body.appendChild(a); a.click();
            document.body.removeChild(a); URL.revokeObjectURL(url);
        };
        // Zoom por defecto del visor de reportes en 100% (no hay propiedad .NET; se hace en el cliente vía el
        // callback CustomizeElements del DxReportViewer). Se aplica una sola vez por instancia del visor.
        window.sgpaViewerDefaultZoom = function (s, e) {
            try {
                if (!s || s.__sgpaZoomSet) return;
                var model = s.GetPreviewModel ? s.GetPreviewModel() : null;
                if (model && typeof model.zoom === 'function') {
                    model.zoom(1);          // 1 = 100%
                    s.__sgpaZoomSet = true;
                }
            } catch (err) { }
        };

        // Trae el PDF del endpoint (que lo genera fuera del circuito) y recién entonces lo abre/descarga.
        // Devuelve cuando termina, así Blazor puede mostrar el wait dialog mientras tanto.
        window.sgpaOpenPdf = async (url, download, fileName) => {
            const resp = await fetch(url, { credentials: 'same-origin' });
            if (!resp.ok) { alert('No se pudo generar el PDF.'); return; }
            const blobUrl = URL.createObjectURL(await resp.blob());
            if (download) {
                const a = document.createElement('a');
                a.href = blobUrl; a.download = fileName || 'reporte.pdf';
                document.body.appendChild(a); a.click(); document.body.removeChild(a);
            } else {
                window.open(blobUrl, '_blank');
            }
            setTimeout(() => URL.revokeObjectURL(blobUrl), 60000);
        };
    </script>
</body>

</html>
