@using DevExpress.Blazor.Reporting
@using DevExpress.XtraReports.UI
@using Microsoft.JSInterop
@using Sgpa.Web.Reporting.Predefinidos
@inject IReportesPredefinidos Reportes
@inject IJSRuntime JS

@* Diálogo genérico de impresión de reportes predefinidos de una pantalla/entidad: lista con checkboxes; Ver =
   vista previa de los tildados fusionados; Imprimir = PDF fusionado inline (batch). Se abre vía @ref Open(entidad, id).
   Mismo enfoque que el diálogo de préstamos, pero reutilizable. *@
<DxPopup @bind-Visible="_visible" HeaderText="@_titulo" Width="460px" CloseOnEscape="true">
    <BodyContentTemplate>
        @if (!_disponibles.Any())
        {
            <div class="text-muted">No hay reportes predefinidos para esta pantalla.</div>
        }
        else
        {
            <div class="mb-2 text-muted small">Tildá los reportes y elegí <b>Ver</b> (vista previa, todos juntos) o <b>Imprimir</b> (batch).</div>
            @foreach (var d in _disponibles)
            {
                <div class="form-check py-1">
                    <input class="form-check-input" type="checkbox" id="@($"repp-{d.Key}")"
                           checked="@_sel.Contains(d.Key)" @onchange="@(e => Toggle(d.Key, (bool)(e.Value ?? false)))" />
                    <label class="form-check-label" for="@($"repp-{d.Key}")">
                        <i class="fa-solid @d.Icono me-1 text-primary"></i> @d.Nombre
                    </label>
                </div>
            }
            <div class="d-flex justify-content-between align-items-center mt-3">
                <a class="small text-decoration-none" @onclick="ToggleTodos" @onclick:preventDefault href="#">
                    @(_sel.Count == _disponibles.Count ? "Destildar todos" : "Tildar todos")
                </a>
                <div class="d-flex gap-2">
                    <DxButton Text="Ver" IconCssClass="fa-solid fa-eye" RenderStyle="ButtonRenderStyle.Primary"
                              Enabled="@(_sel.Count > 0 && !_busy)" Click="VerAsync" />
                    <DxButton Text="Imprimir" IconCssClass="fa-solid fa-print" RenderStyle="ButtonRenderStyle.Secondary"
                              Enabled="@(_sel.Count > 0 && !_busy)" Click="ImprimirAsync" />
                </div>
            </div>
        }
    </BodyContentTemplate>
</DxPopup>

<DxPopup @bind-Visible="_viewerVisible" HeaderText="Vista previa" Width="95vw" Height="92vh" CloseOnEscape="true">
    <BodyContentTemplate>
        @if (_report is not null)
        {
            <div class="sgpa-report-viewer-host">
                <DxReportViewer Report="_report" />
            </div>
        }
    </BodyContentTemplate>
</DxPopup>

<SgpaWaitDialog Visible="_busy" Text="Generando reporte…" />

@code {
    private string _entidad = "";
    private IReadOnlyList<long> _ids = Array.Empty<long>();
    private string _titulo = "Reportes";
    private bool _visible, _viewerVisible, _busy;
    private readonly HashSet<string> _sel = new(StringComparer.Ordinal);
    private IReadOnlyList<ReportePredefDef> _disponibles = Array.Empty<ReportePredefDef>();
    private XtraReport? _report;

    // Per-registro: un único id (CI, código…). Conveniencia.
    public void Open(string entidad, long id) => Open(entidad, new[] { id }, id > 0 ? $"Reportes — {entidad} {id}" : $"Reportes — {entidad}");

    // Por selección: las claves seleccionadas en la grilla (p.ej. NroLlamado de certificaciones).
    public void Open(string entidad, IReadOnlyList<long> ids, string? titulo = null)
    {
        _entidad = entidad;
        _ids = ids ?? Array.Empty<long>();
        _disponibles = Reportes.Para(entidad);
        _titulo = titulo ?? $"Reportes — {entidad}";
        _sel.Clear();   // sin nada tildado por defecto
        _visible = true;
        StateHasChanged();
    }

    // Vista previa directa de UN reporte (desde el menú del split-button), sin pasar por la lista con checkboxes.
    public async Task PreviewAsync(string entidad, IReadOnlyList<long> ids, string key)
    {
        _entidad = entidad;
        _ids = ids ?? Array.Empty<long>();
        _busy = true; StateHasChanged();
        try { _report = await Reportes.BuildAsync(entidad, new[] { key }, _ids); }
        finally { _busy = false; }
        _viewerVisible = _report is not null;
        StateHasChanged();
    }

    private void Toggle(string key, bool on) { if (on) _sel.Add(key); else _sel.Remove(key); }

    private void ToggleTodos()
    {
        if (_sel.Count == _disponibles.Count) _sel.Clear();
        else foreach (var d in _disponibles) _sel.Add(d.Key);
    }

    private async Task VerAsync()
    {
        _busy = true; StateHasChanged();
        try { _report = await Reportes.BuildAsync(_entidad, _sel, _ids); }
        finally { _busy = false; }
        _viewerVisible = _report is not null;
    }

    private async Task ImprimirAsync()
        => await JS.InvokeVoidAsync("window.open",
            $"/reportes/predef/{_entidad}/pdf?keys={string.Join(',', _sel)}&ids={string.Join(',', _ids)}", "_blank");
}
