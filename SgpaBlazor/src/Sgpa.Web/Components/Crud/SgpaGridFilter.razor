@using DevExpress.Data.Filtering
@using Sgpa.Domain.Metadata
@using Sgpa.Data.Crud
@using Sgpa.Data.Configuracion
@inject ISavedFilterService Filters
@inject WebCurrentUser CurrentUser
@inject IToastNotificationService Toasts
@inject ISgpaLookupService Lookups
@inject ITablaConfigService TablaConfig

@*
    Filtrado interactivo del ListView con DxFilterBuilder (FilterControl de DevExpress) + filtros
    guardados (equivalente moderno de la tabla VB6 'Seleccion'). Un DxDropDownButton "Filtros"
    lista los guardados para aplicar de un clic; el criterio se aplica al grid vía SetFilterCriteria
    (y, como el grid traduce FilterCriteria→SQL, funciona también server-side).
*@
<DxDropDownButton Text="Filtros" IconCssClass="fa-solid fa-filter" RenderStyle="ButtonRenderStyle.Secondary">
    <Items>
        @foreach (var f in _saved)
        {
            <DxDropDownButtonItem Text="@f.Nombre" IconCssClass="@(f.EsSistema ? "fa-solid fa-lock" : "fa-solid fa-bookmark")"
                                  Click="@(() => ApplySaved(f))" />
        }
        <DxDropDownButtonItem Text="Filtro avanzado…" IconCssClass="fa-solid fa-sliders" BeginGroup="true" Click="OpenBuilderAsync" />
        <DxDropDownButtonItem Text="Guardar filtro actual…" IconCssClass="fa-solid fa-floppy-disk" Click="OpenSaveAsync" />
        <DxDropDownButtonItem Text="Administrar filtros…" IconCssClass="fa-solid fa-list-check" Click="OpenManageAsync" />
        <DxDropDownButtonItem Text="Quitar filtro" IconCssClass="fa-solid fa-filter-circle-xmark" BeginGroup="true" Click="ClearFilter" />
    </Items>
</DxDropDownButton>

@* ---- Popup: filtro avanzado (FilterBuilder) ---- *@
<DxPopup @bind-Visible="_builderVisible" HeaderText="Filtro avanzado" Width="640px" CloseOnEscape="true">
    <BodyContentTemplate>
        <DxFilterBuilder @bind-FilterCriteria="_builderCriteria">
            <Fields>
                @foreach (var col in Meta.ListColumns)
                {
                    @if (_fkLookups.TryGetValue(col.Name, out var fklk))
                    {
                        @* Columna FK: el valor se elige de un combo de lookup (descripción), guardando el código. *@
                        <DxFilterBuilderField FieldName="@col.Name" Caption="@col.Caption" Type="col.UnderlyingType">
                            <EditSettings>
                                <DxComboBoxSettings Data="fklk"
                                                    ValueFieldName="@nameof(LookupItem.Value)" TextFieldName="@nameof(LookupItem.Text)"
                                                    FilteringMode="DataGridFilteringMode.Contains" />
                            </EditSettings>
                        </DxFilterBuilderField>
                    }
                    else
                    {
                        <DxFilterBuilderField FieldName="@col.Name" Caption="@col.Caption" Type="col.UnderlyingType" />
                    }
                }
                @* Campos calculados (server-side): se traducen inline en el WHERE. *@
                @foreach (var cf in CalcFields)
                {
                    <DxFilterBuilderField FieldName="@cf.Nombre" Caption="@($"ƒ {cf.Caption}")" Type="cf.ClrType" />
                }
                @* Relaciones a otras tablas como campos JERÁRQUICOS (no ensucian el root):
                   - 1-N (colección): IsCollection=true → el builder arma un Exists; subcampos con FieldName RELATIVO.
                   - N-1 (referencia/FK): nodo de navegación; subcampos con FieldName de PATH COMPLETO ("Banco.Nombre").
                   En ambos casos el traductor + DapperCrudService lo resuelven como un EXISTS sobre la tabla destino. *@
                @foreach (var rel in EntityRelations.For(Meta.EntityType))
                {
                    @if (rel.IsCollection)
                    {
                        <DxFilterBuilderField FieldName="@rel.FieldPrefix" Caption="@RelLabel(rel)" IsCollection="true">
                            <Fields>
                                @foreach (var col in rel.Child.ListColumns)
                                {
                                    <DxFilterBuilderField FieldName="@col.Name" Caption="@col.Caption" Type="col.UnderlyingType" />
                                }
                            </Fields>
                        </DxFilterBuilderField>
                    }
                    else
                    {
                        @* Nodo de referencia N-1: sólo agrupa; NO es columna real → no seleccionable en sí.
                           Se elige una columna hija (ej. Mutualista · Descripción), que filtra vía EXISTS. *@
                        <DxFilterBuilderField FieldName="@rel.FieldPrefix" Caption="@RelLabel(rel)" AllowSelection="false">
                            <Fields>
                                @foreach (var col in rel.Child.ListColumns)
                                {
                                    <DxFilterBuilderField FieldName="@($"{rel.FieldPrefix}.{col.Name}")"
                                                          Caption="@col.Caption"
                                                          CaptionFullPath="@($"{RelLabel(rel)}.{col.Caption}")"
                                                          Type="col.UnderlyingType" />
                                }
                            </Fields>
                        </DxFilterBuilderField>
                    }
                }
            </Fields>
        </DxFilterBuilder>
        <div class="d-flex gap-2 mt-3">
            <DxButton Text="Aplicar" IconCssClass="fa-solid fa-check" RenderStyle="ButtonRenderStyle.Primary" Click="ApplyBuilderAsync" />
            <DxButton Text="Limpiar" RenderStyle="ButtonRenderStyle.Link" Click="@(() => _builderCriteria = null)" />
        </div>
    </BodyContentTemplate>
</DxPopup>

@* ---- Popup: guardar filtro actual (+ parametrizar valores) ---- *@
<DxPopup @bind-Visible="_saveVisible" HeaderText="Guardar filtro" Width="560px" CloseOnEscape="true">
    <BodyContentTemplate>
        @if (_error is not null) { <div class="alert alert-danger py-2">@_error</div> }
        <p class="text-muted small mb-2">Se guarda el filtro activo del listado con el nombre indicado.</p>
        <div class="d-flex gap-2 align-items-center mb-3">
            <DxTextBox @bind-Text="_newName" NullText="Nombre del filtro…" />
            <DxButton Text="Guardar" IconCssClass="fa-solid fa-floppy-disk" RenderStyle="ButtonRenderStyle.Primary" Click="SaveCurrentAsync" />
        </div>
        @if (_saveLeaves.Count > 0)
        {
            <p class="text-muted small mb-1"><i class="fa-solid fa-circle-question me-1"></i>
                Marcá los valores que el sistema debe <strong>pedir cada vez que se ejecute</strong> el filtro
                (los no marcados quedan fijos):</p>
            <ul class="list-group">
                @foreach (var lf in _saveLeaves)
                {
                    <li class="list-group-item d-flex align-items-center gap-2 py-1">
                        <DxCheckBox @bind-Checked="_leafCheckedRef[lf.Indice]" />
                        <span class="flex-grow-1">@lf.Caption
                            <span class="text-muted">= @(lf.ValorActual ?? "—")</span></span>
                        @if (_leafCheckedRef[lf.Indice])
                        {
                            <DxTextBox Text="@(_leafNames.TryGetValue(lf.Indice, out var nm) ? nm : lf.Caption)"
                                       TextChanged="@(v => _leafNames[lf.Indice] = v)"
                                       NullText="etiqueta a mostrar" Width="200px" />
                        }
                    </li>
                }
            </ul>
        }
    </BodyContentTemplate>
</DxPopup>

@* ---- Popup: pedir parámetros al ejecutar (estilo Request Parameters de XtraReports) ---- *@
<DxPopup @bind-Visible="_promptVisible" HeaderText="@($"Parámetros — {_promptFilter?.Nombre}")" Width="480px" CloseOnEscape="true">
    <BodyContentTemplate>
        <ParametrosPrompt Defs="_promptDefs" Initial="_promptInitial" ShowCancel="true"
                          OnAccept="OnParamsAccepted" OnCancel="@(() => _promptVisible = false)" />
    </BodyContentTemplate>
</DxPopup>

@* ---- Popup: administrar (borrar) ---- *@
<DxPopup @bind-Visible="_manageVisible" HeaderText="Administrar filtros" Width="520px" CloseOnEscape="true">
    <BodyContentTemplate>
        @if (_saved.Count == 0)
        {
            <p class="text-muted">No hay filtros guardados para esta lista.</p>
        }
        else
        {
            <ul class="list-group">
                @foreach (var f in _saved)
                {
                    <li class="list-group-item d-flex align-items-center justify-content-between">
                        <span><i class="fa-solid @(f.EsSistema ? "fa-lock" : "fa-bookmark") me-2 text-muted"></i>@f.Nombre</span>
                        <span class="d-flex gap-2">
                            <DxButton Text="Aplicar" RenderStyle="ButtonRenderStyle.Link" Click="@(() => ApplySaved(f))" />
                            @if (!f.EsSistema)
                            {
                                <DxButton IconCssClass="fa-solid fa-trash" RenderStyle="ButtonRenderStyle.Link" Tooltip="Borrar"
                                          Click="@(() => DeleteSavedAsync(f))" />
                            }
                        </span>
                    </li>
                }
            </ul>
        }
    </BodyContentTemplate>
</DxPopup>

@code {
    [Parameter] public DxGrid? Grid { get; set; }
    [Parameter, EditorRequired] public EntityMetadata Meta { get; set; } = default!;
    /// <summary>Se invoca tras aplicar/limpiar un filtro (para refrescar contadores del padre).</summary>
    [Parameter] public EventCallback OnChanged { get; set; }
    /// <summary>Campos calculados de la tabla, filtrables en modo servidor (se traducen inline en el WHERE).</summary>
    [Parameter] public IReadOnlyList<CalculatedField> CalcFields { get; set; } = Array.Empty<CalculatedField>();

    // Resolver de tipo para campos calculados (alimenta la inferencia de tipo del parámetro al guardar el filtro).
    private Type? CalcType(string nombre)
        => CalcFields.FirstOrDefault(c => c.Nombre.Equals(nombre, StringComparison.OrdinalIgnoreCase))?.ClrType;

    private bool _builderVisible, _saveVisible, _manageVisible;
    private CriteriaOperator? _builderCriteria;
    private IReadOnlyList<SavedFilter> _saved = Array.Empty<SavedFilter>();
    private string _newName = string.Empty;
    private string? _error;

    // Autoría: criterio que se está guardando + hojas parametrizables (check + nombre por hoja).
    private CriteriaOperator? _saveCrit;
    private IReadOnlyList<FiltroLeaf> _saveLeaves = Array.Empty<FiltroLeaf>();
    private readonly Dictionary<int, bool> _leafCheckedRef = new();
    private readonly Dictionary<int, string> _leafNames = new();

    // Ejecución: prompt de parámetros + últimos valores usados por filtro (recordar dentro de la sesión).
    private bool _promptVisible;
    private SavedFilter? _promptFilter;
    private CriteriaOperator? _promptCrit;
    private IReadOnlyList<FiltroParametroDef> _promptDefs = Array.Empty<FiltroParametroDef>();
    private IReadOnlyDictionary<string, object?>? _promptInitial;
    private readonly Dictionary<int, Dictionary<string, object?>> _ultimosValores = new();

    // Lookups de las columnas FK de la entidad, para el combo del filter builder (col física -> items).
    private readonly Dictionary<string, IReadOnlyList<LookupItem>> _fkLookups = new();

    protected override async Task OnInitializedAsync()
    {
        await TablaConfig.EnsureLoadedAsync();
        await ReloadSavedAsync();
        await CargarLookupsFkAsync();
    }

    // Nombre amigable del nodo de relación: alias del admin (Configuración de tablas) si existe; si no, la
    // etiqueta curada (Empleos/…) o el DisplayName de la tabla. Misma idea que el Caption de los campos.
    private string RelLabel(ExistsRelation rel)
    {
        // Sin alias del admin pero con etiqueta curada (Empleos/…): usar la curada; si no, DisplayName (alias ?? tabla).
        var alias = TablaConfig.Get(rel.Child.Table).Alias;
        if (string.IsNullOrWhiteSpace(alias) && !rel.Label.Equals(rel.Child.Table, StringComparison.Ordinal))
            return rel.Label;
        return TablaConfig.DisplayName(rel.Child.Table);
    }

    private async Task CargarLookupsFkAsync()
    {
        foreach (var col in Meta.ListColumns)
        {
            if (col.IsAudit || col.IsKey) continue;
            var target = EntityCatalog.LookupTargetFor(col, Meta);
            if (target is null) continue;
            var items = await Lookups.GetAsync(target.EntityType);
            if (items is not null) _fkLookups[col.Name] = items;
        }
    }

    private async Task ReloadSavedAsync()
    {
        await CurrentUser.EnsureLoadedAsync();
        _saved = await Filters.GetForEntityAsync(Meta.Table, CurrentUser.UserName);
    }

    private Task OpenBuilderAsync()
    {
        _builderCriteria = Grid?.GetFilterCriteria();
        _builderVisible = true;
        return Task.CompletedTask;
    }

    private async Task ApplyBuilderAsync()
    {
        Grid?.SetFilterCriteria(_builderCriteria);
        _builderVisible = false;
        await OnChanged.InvokeAsync();
    }

    private async Task ApplySaved(SavedFilter f)
    {
        try
        {
            _error = null;
            var crit = CriteriaOperator.Parse(f.Criteria);
            var defs = FiltroParametros.DeserializarDefs(f.Parametros);
            if (defs.Count > 0)
            {
                // El filtro tiene parámetros: pedirlos antes de aplicar (no se aplica todavía).
                _promptFilter = f;
                _promptCrit = crit;
                _promptDefs = defs;
                _ultimosValores.TryGetValue(f.Id, out var last);   // recordar últimos valores de la sesión
                _promptInitial = last;
                _manageVisible = false;
                _promptVisible = true;
                return;
            }
            Grid?.SetFilterCriteria(crit);
            _manageVisible = false;
            await OnChanged.InvokeAsync();
        }
        catch (Exception ex) { Toasts.Error($"No se pudo aplicar el filtro: {ex.Message}"); }
    }

    private Task OpenSaveAsync()
    {
        _error = null;
        _newName = string.Empty;
        _saveCrit = Grid?.GetFilterCriteria();
        _leafCheckedRef.Clear();
        _leafNames.Clear();
        _saveLeaves = ReferenceEquals(_saveCrit, null)
            ? Array.Empty<FiltroLeaf>()
            : FiltroParametros.Enumerar(_saveCrit, Meta.EntityType, CalcType);
        foreach (var lf in _saveLeaves) { _leafCheckedRef[lf.Indice] = false; _leafNames[lf.Indice] = lf.Caption; }
        _saveVisible = true;
        return Task.CompletedTask;
    }

    private async Task SaveCurrentAsync()
    {
        _error = null;
        if (string.IsNullOrWhiteSpace(_newName)) { _error = "Indicá un nombre."; return; }
        var crit = _saveCrit;
        if (ReferenceEquals(crit, null) || string.IsNullOrWhiteSpace(crit.ToString())) { _error = "No hay filtro activo para guardar."; return; }

        var chosen = new Dictionary<int, string>();
        foreach (var lf in _saveLeaves)
            if (_leafCheckedRef.TryGetValue(lf.Indice, out var ck) && ck)
            {
                var nm = (_leafNames.TryGetValue(lf.Indice, out var n) ? n : lf.SugerenciaNombre)?.Trim();
                if (string.IsNullOrWhiteSpace(nm)) { _error = $"Falta el nombre del parámetro para «{lf.Caption}»."; return; }
                chosen[lf.Indice] = nm;
            }

        string critText;
        string? paramsJson = null;
        if (chosen.Count > 0)
        {
            var (pc, defs) = FiltroParametros.Parametrizar(crit, Meta.EntityType, chosen, CalcType);
            critText = pc!.ToString();
            paramsJson = FiltroParametros.SerializarDefs(defs);
        }
        else critText = crit.ToString();

        await Filters.SaveAsync(Meta.Table, _newName.Trim(), critText, CurrentUser.UserName, paramsJson);
        _saveVisible = false;
        await ReloadSavedAsync();
    }

    // Aplica el filtro parametrizado tras pedir los valores (ParametrosPrompt ya validó los requeridos):
    // recuerda los últimos valores de la sesión, sustituye los parámetros y setea el criterio en la grilla.
    private async Task OnParamsAccepted(IReadOnlyDictionary<string, object?> vals)
    {
        if (_promptFilter is not null) _ultimosValores[_promptFilter.Id] = new Dictionary<string, object?>(vals);
        Grid?.SetFilterCriteria(FiltroParametros.Sustituir(_promptCrit, vals));
        _promptVisible = false;
        await OnChanged.InvokeAsync();
    }

    private async Task OpenManageAsync()
    {
        await ReloadSavedAsync();
        _manageVisible = true;
    }

    private async Task DeleteSavedAsync(SavedFilter f)
    {
        await Filters.DeleteAsync(f.Id);
        await ReloadSavedAsync();
    }

    private async Task ClearFilter()
    {
        Grid?.ClearFilter();
        await OnChanged.InvokeAsync();
    }
}
