@using Dapper
@using DevExpress.Data.Filtering
@using Sgpa.Data
@using Sgpa.Data.Crud
@using Sgpa.Domain.Metadata
@implements IAsyncDisposable
@inject IJSRuntime JS
@inject IDbExecutor Db

@*
    Editor visual de fórmulas para campos calculados (inspirado en el Expression Editor de DevExpress XtraReports):
    paleta de CAMPOS + FUNCIONES por categoría + operadores (insertados en el cursor), autocompletado al tipear '[',
    validación en vivo (parse + columnas) y vista previa del valor sobre una fila de muestra. El texto es una
    expresión CriteriaOperator traducida a SQL por ScalarSqlTranslator.
*@
@{ EnsureFields(); }
<div class="row g-2">
    <div class="col-lg-5">
        <div class="border rounded p-2 sgpa-formula-palette" style="max-height:300px; overflow:auto">
            <div class="fw-semibold small text-muted">Campos</div>
            @if (!string.IsNullOrEmpty(_loadInfo)) { <div class="small text-info">@_loadInfo</div> }
            @if (_columns.Count == 0)
            {
                <div class="text-muted small mb-2">Elegí la tabla para ver sus campos.</div>
            }
            else
            {
                <div class="d-flex flex-wrap gap-1 mb-2">
                    @foreach (var col in _columns)
                    {
                        <button type="button" class="btn btn-sm btn-outline-secondary py-0" title="@col.Name"
                                @onclick="@(() => Insert($"[{col.Name}]", -1))">@col.Caption</button>
                    }
                </div>
            }

            <div class="fw-semibold small text-muted">Operadores</div>
            <div class="d-flex flex-wrap gap-1 mb-2">
                @foreach (var op in new[] { "+", "-", "*", "/" })
                {
                    <button type="button" class="btn btn-sm btn-outline-secondary py-0" @onclick="@(() => Insert($" {op} ", -1))">@op</button>
                }
                <button type="button" class="btn btn-sm btn-outline-secondary py-0" @onclick="@(() => Insert("(", -1))">(</button>
                <button type="button" class="btn btn-sm btn-outline-secondary py-0" @onclick="@(() => Insert(")", -1))">)</button>
            </div>

            @foreach (var grupo in _funciones.GroupBy(f => f.Cat))
            {
                <div class="fw-semibold small text-muted">@grupo.Key</div>
                <div class="d-flex flex-wrap gap-1 mb-2">
                    @foreach (var f in grupo)
                    {
                        <button type="button" class="btn btn-sm btn-outline-info py-0" title="@f.Hint"
                                @onclick="@(() => Insert($"{f.Name}({Args(f.Arity)})", f.Name.Length + 1))">@f.Name</button>
                    }
                </div>
            }

            @* Campos de tablas relacionadas (N-1, un nivel): se insertan como [Tabla.Columna] y el motor los resuelve
               con una subconsulta correlacionada. *@
            @foreach (var rel in _relations)
            {
                <div class="fw-semibold small text-muted">@rel.TargetLabel <span class="text-muted">(relación)</span></div>
                <div class="d-flex flex-wrap gap-1 mb-2">
                    @foreach (var col in rel.Cols)
                    {
                        <button type="button" class="btn btn-sm btn-outline-warning py-0" title="@($"{rel.Target}.{col.Name}")"
                                @onclick="@(() => Insert($"[{rel.Target}.{col.Name}]", -1))">@col.Caption</button>
                    }
                </div>
            }
        </div>
    </div>
    <div class="col-lg-7">
        <textarea @ref="_ta" class="form-control font-monospace" rows="6" spellcheck="false"
                  value="@Expression" @oninput="OnInput" placeholder="ej. DateDiffDay([FechaIni],[FechaFin]) + 1"></textarea>

        @* Autocompletado: sugerencias de campos mientras hay un '[' abierto. *@
        @if (_suggest.Count > 0)
        {
            <div class="border rounded mt-1 p-1 d-flex flex-wrap gap-1 bg-light">
                @foreach (var s in _suggest)
                {
                    <button type="button" class="btn btn-sm btn-light border py-0" @onclick="@(() => ConfirmSuggestion(s))">
                        <i class="fa-solid fa-table-column me-1 text-muted"></i>@s.Caption <span class="text-muted small">@s.Name</span>
                    </button>
                }
            </div>
        }

        <div class="d-flex align-items-center gap-2 mt-1">
            <DxButton Text="Probar" IconCssClass="fa-solid fa-flask" RenderStyle="ButtonRenderStyle.Secondary"
                      SizeMode="SizeMode.Small" Click="ProbarAsync" Enabled="@(!string.IsNullOrWhiteSpace(Expression) && _error is null)" />
            <div class="small">
                @if (string.IsNullOrWhiteSpace(Expression))
                {
                    <span class="text-muted">Escribí o insertá campos y funciones desde la izquierda.</span>
                }
                else if (_error is not null)
                {
                    <span class="text-danger"><i class="fa-solid fa-triangle-exclamation me-1"></i>@_error</span>
                }
                else if (_previewError is not null)
                {
                    <span class="text-danger"><i class="fa-solid fa-triangle-exclamation me-1"></i>@_previewError</span>
                }
                else if (_preview is not null)
                {
                    <span class="text-success"><i class="fa-solid fa-check me-1"></i>Válida. Ejemplo: <strong>@_preview</strong></span>
                }
                else
                {
                    <span class="text-success"><i class="fa-solid fa-check me-1"></i>Expresión válida.</span>
                }
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter] public string? Tabla { get; set; }
    [Parameter] public string? Expression { get; set; }
    [Parameter] public EventCallback<string?> ExpressionChanged { get; set; }

    private ElementReference _ta;
    private IJSObjectReference? _module;
    private IReadOnlyList<ColumnMetadata> _columns = Array.Empty<ColumnMetadata>();
    private List<(string Target, string TargetLabel, IReadOnlyList<ColumnMetadata> Cols)> _relations = new();
    private string? _error;
    private string? _validatedTabla;
    private string? _loadInfo;   // diagnóstico visible: qué tabla llegó y cuántos campos cargaron

    // Vista previa.
    private string? _preview;
    private string? _previewError;

    // Autocompletado.
    private List<ColumnMetadata> _suggest = new();
    private int _openIndex = -1;     // posición del '[' abierto
    private int _caretStart;         // posición del cursor al sugerir

    private sealed record FnDef(string Cat, string Name, string Hint, int Arity);
    private static readonly FnDef[] _funciones =
    {
        new("Fecha", "DateDiffDay", "Días entre dos fechas: DateDiffDay(desde, hasta)", 2),
        new("Fecha", "DateDiffMonth", "Meses entre dos fechas", 2),
        new("Fecha", "DateDiffYear", "Años entre dos fechas", 2),
        new("Fecha", "AddDays", "Suma días a una fecha: AddDays(fecha, n)", 2),
        new("Fecha", "AddMonths", "Suma meses a una fecha", 2),
        new("Fecha", "AddYears", "Suma años a una fecha", 2),
        new("Texto", "Concat", "Concatena: Concat(a, b, ...)", 2),
        new("Texto", "Substring", "Substring(texto, inicio, largo)", 3),
        new("Texto", "Len", "Largo del texto", 1),
        new("Texto", "Upper", "Mayúsculas", 1),
        new("Texto", "Lower", "Minúsculas", 1),
        new("Texto", "Trim", "Quita espacios", 1),
        new("Lógicas", "Iif", "Iif(condición, siValor, siNo)", 3),
        new("Lógicas", "IsNull", "IsNull(valor, alternativo)", 2),
        new("Matemáticas", "Abs", "Valor absoluto", 1),
        new("Matemáticas", "Round", "Round(valor, decimales)", 2),
    };

    // Comas/placeholders según la aridad: 1 arg → "" (cursor adentro); 2 → ", "; 3 → ", , ".
    private static string Args(int arity) => arity <= 1 ? string.Empty : string.Join(", ", new string[arity]);

    protected override void OnParametersSet()
    {
        EnsureFields();
        Validate();
    }

    // Recalcula campos + relaciones desde el parámetro Tabla ACTUAL (cacheado por tabla). Se llama también en cada
    // render (markup) para no depender del diff de OnParametersSet.
    private void EnsureFields()
    {
        if (string.Equals(_validatedTabla, Tabla, StringComparison.OrdinalIgnoreCase)) return;
        _validatedTabla = Tabla;
        _preview = null; _previewError = null;
        try
        {
            var meta = string.IsNullOrWhiteSpace(Tabla) ? null : EntityCatalog.TryGet(Tabla);
            _columns = meta?.Columns.Where(c => !c.IsAudit).ToList() ?? (IReadOnlyList<ColumnMetadata>)Array.Empty<ColumnMetadata>();
            _relations = new();
            if (meta is not null)
            {
                var vistos = new HashSet<string>(StringComparer.OrdinalIgnoreCase);
                foreach (var fk in meta.Columns)
                {
                    if (fk.IsAudit) continue;
                    var target = EntityCatalog.LookupDisplayTargetFor(fk, meta);
                    if (target is null || !vistos.Add(target.Table)) continue;
                    _relations.Add((target.Table, target.Table, target.Columns.Where(c => !c.IsAudit).ToList()));
                }
            }
            _loadInfo = $"Tabla='{Tabla}' · {_columns.Count} campos · {_relations.Count} relaciones";
        }
        catch (Exception ex)
        {
            _columns = Array.Empty<ColumnMetadata>(); _relations = new();
            _loadInfo = "ERROR cargando campos: " + ex.Message;
        }
    }

    private async Task<IJSObjectReference> ModuleAsync()
        => _module ??= await JS.InvokeAsync<IJSObjectReference>("import", "./js/formula-editor.js");

    private async Task OnInput(ChangeEventArgs e)
    {
        Expression = e.Value?.ToString();
        _preview = null; _previewError = null;
        await ExpressionChanged.InvokeAsync(Expression);
        Validate();
        await UpdateSuggestionsAsync();
    }

    private async Task Insert(string snippet, int caretOffset)
    {
        var mod = await ModuleAsync();
        var nuevo = await mod.InvokeAsync<string?>("insertAtCursor", _ta, snippet, caretOffset);
        Expression = nuevo;
        _preview = null; _previewError = null;
        await ExpressionChanged.InvokeAsync(Expression);
        Validate();
        _suggest.Clear();
    }

    // Muestra sugerencias de campos si el cursor está dentro de un '[' sin cerrar.
    private async Task UpdateSuggestionsAsync()
    {
        _suggest = new();
        if (_columns.Count == 0 || string.IsNullOrEmpty(Expression)) return;
        var mod = await ModuleAsync();
        var caret = await mod.InvokeAsync<CaretInfo?>("getCaret", _ta);
        var start = caret?.Start ?? Expression.Length;
        if (start > Expression.Length) start = Expression.Length;

        var open = Expression.LastIndexOf('[', Math.Max(0, start - 1));
        if (open < 0) return;
        var fragment = Expression.Substring(open + 1, start - open - 1);
        if (fragment.Contains(']')) return;   // corchete ya cerrado

        _openIndex = open;
        _caretStart = start;
        _suggest = _columns
            .Where(c => fragment.Length == 0
                        || c.Name.Contains(fragment, StringComparison.OrdinalIgnoreCase)
                        || c.Caption.Contains(fragment, StringComparison.OrdinalIgnoreCase))
            .Take(8).ToList();
    }

    private async Task ConfirmSuggestion(ColumnMetadata col)
    {
        var mod = await ModuleAsync();
        var nuevo = await mod.InvokeAsync<string?>("replaceRange", _ta, _openIndex, _caretStart, $"[{col.Name}]", -1);
        Expression = nuevo;
        _suggest.Clear();
        _preview = null; _previewError = null;
        await ExpressionChanged.InvokeAsync(Expression);
        Validate();
    }

    private async Task ProbarAsync()
    {
        _preview = null; _previewError = null;
        var meta = string.IsNullOrWhiteSpace(Tabla) ? null : EntityCatalog.TryGet(Tabla);
        if (meta is null || string.IsNullOrWhiteSpace(Expression)) return;
        try
        {
            var node = SgpaScalarTranslator.Translate(CriteriaOperator.Parse(Expression));
            var p = new DynamicParameters();
            int n = 0;
            var expr = ScalarSqlTranslator.Translate(node, c => $"[{FilterSqlTranslator.ResolveColumnIn(meta, c).Name}]", p, ref n);
            var sql = $"SELECT TOP 1 ({expr}) AS V FROM {meta.QualifiedTable}";
            var v = await Db.ExecuteScalarAsync<object>(sql, p);
            _preview = v is null ? "(sin filas / null)" : v.ToString();
        }
        catch (Exception ex) { _previewError = ex.Message; }
    }

    private void Validate()
    {
        _error = null;
        if (string.IsNullOrWhiteSpace(Expression)) return;
        var meta = string.IsNullOrWhiteSpace(Tabla) ? null : EntityCatalog.TryGet(Tabla);
        if (meta is null) { _error = "Elegí una tabla válida."; return; }
        try
        {
            var node = SgpaScalarTranslator.Translate(CriteriaOperator.Parse(Expression));
            foreach (var colName in ColumnasDe(node))
                if (!ColumnExists(meta, colName))
                { _error = $"La columna '{colName}' no existe en {meta.Table}."; return; }
        }
        catch (Exception ex) { _error = ex.Message; }
    }

    // Existe la columna (simple) o la relación N-1 + columna destino (nombre "Tabla.Columna").
    private static bool ColumnExists(EntityMetadata meta, string name)
    {
        var dot = name.IndexOf('.');
        if (dot < 0)
            return meta.Columns.Any(c => c.Name.Equals(name, StringComparison.OrdinalIgnoreCase)
                                      || c.Property.Name.Equals(name, StringComparison.OrdinalIgnoreCase));
        var prefix = name[..dot];
        var col = name[(dot + 1)..];
        var target = meta.Columns
            .Select(fk => EntityCatalog.LookupDisplayTargetFor(fk, meta))
            .FirstOrDefault(t => t is not null && t.Table.Equals(prefix, StringComparison.OrdinalIgnoreCase));
        return target is not null && target.Columns.Any(c => c.Name.Equals(col, StringComparison.OrdinalIgnoreCase)
                                                          || c.Property.Name.Equals(col, StringComparison.OrdinalIgnoreCase));
    }

    private static IEnumerable<string> ColumnasDe(ScalarNode node) => node switch
    {
        ScalarColumn c => new[] { c.Name },
        ScalarConst => Array.Empty<string>(),
        ScalarNegate u => ColumnasDe(u.Operand),
        ScalarBinary b => ColumnasDe(b.Left).Concat(ColumnasDe(b.Right)),
        ScalarCondition cn => ColumnasDe(cn.Left).Concat(ColumnasDe(cn.Right)),
        ScalarFunc f => f.Args.SelectMany(ColumnasDe),
        _ => Array.Empty<string>()
    };

    private sealed class CaretInfo { public int Start { get; set; } public string? Value { get; set; } }

    public async ValueTask DisposeAsync()
    {
        if (_module is not null)
        {
            try { await _module.DisposeAsync(); } catch { /* circuito cerrado */ }
        }
    }
}
