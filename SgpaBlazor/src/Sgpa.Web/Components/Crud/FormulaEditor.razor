@using DevExpress.Data.Filtering
@using Sgpa.Data.Crud
@using Sgpa.Domain.Metadata
@implements IAsyncDisposable
@inject IJSRuntime JS

@*
    Editor visual de fórmulas para campos calculados (inspirado en el Expression Editor de DevExpress XtraReports):
    paleta de CAMPOS de la tabla + FUNCIONES por categoría + operadores, que se insertan en la posición del cursor;
    el texto sigue siendo una expresión CriteriaOperator y se valida en vivo (parse + existencia de columnas) con el
    mismo motor (SgpaScalarTranslator) que traduce a SQL.
*@
<div class="row g-2">
    <div class="col-lg-5">
        <div class="border rounded p-2 sgpa-formula-palette" style="max-height:260px; overflow:auto">
            <div class="fw-semibold small text-muted">Campos</div>
            @if (_columns.Count == 0)
            {
                <div class="text-muted small mb-2">Elegí la tabla para ver sus campos.</div>
            }
            else
            {
                <div class="d-flex flex-wrap gap-1 mb-2">
                    @foreach (var col in _columns)
                    {
                        <button type="button" class="btn btn-sm btn-outline-secondary py-0" title="@col.Name"
                                @onclick="@(() => Insert($"[{col.Name}]", -1))">@col.Caption</button>
                    }
                </div>
            }

            <div class="fw-semibold small text-muted">Operadores</div>
            <div class="d-flex flex-wrap gap-1 mb-2">
                @foreach (var op in new[] { "+", "-", "*", "/" })
                {
                    <button type="button" class="btn btn-sm btn-outline-secondary py-0" @onclick="@(() => Insert($" {op} ", -1))">@op</button>
                }
                <button type="button" class="btn btn-sm btn-outline-secondary py-0" @onclick="@(() => Insert("(", -1))">(</button>
                <button type="button" class="btn btn-sm btn-outline-secondary py-0" @onclick="@(() => Insert(")", -1))">)</button>
            </div>

            @foreach (var grupo in _funciones.GroupBy(f => f.Cat))
            {
                <div class="fw-semibold small text-muted">@grupo.Key</div>
                <div class="d-flex flex-wrap gap-1 mb-2">
                    @foreach (var f in grupo)
                    {
                        <button type="button" class="btn btn-sm btn-outline-info py-0" title="@f.Hint"
                                @onclick="@(() => Insert($"{f.Name}()", f.Name.Length + 1))">@f.Name</button>
                    }
                </div>
            }
        </div>
    </div>
    <div class="col-lg-7">
        <textarea @ref="_ta" class="form-control font-monospace" rows="6" spellcheck="false"
                  value="@Expression" @oninput="OnInput" placeholder="ej. DateDiffDay([FechaIni],[FechaFin]) + 1"></textarea>
        <div class="mt-1 small">
            @if (string.IsNullOrWhiteSpace(Expression))
            {
                <span class="text-muted">Escribí o insertá campos y funciones desde la izquierda.</span>
            }
            else if (_error is not null)
            {
                <span class="text-danger"><i class="fa-solid fa-triangle-exclamation me-1"></i>@_error</span>
            }
            else
            {
                <span class="text-success"><i class="fa-solid fa-check me-1"></i>Expresión válida.</span>
            }
        </div>
    </div>
</div>

@code {
    [Parameter] public string? Tabla { get; set; }
    [Parameter] public string? Expression { get; set; }
    [Parameter] public EventCallback<string?> ExpressionChanged { get; set; }

    private ElementReference _ta;
    private IJSObjectReference? _module;
    private IReadOnlyList<ColumnMetadata> _columns = Array.Empty<ColumnMetadata>();
    private string? _error;
    private string? _validatedTabla;

    private sealed record FnDef(string Cat, string Name, string Hint);
    private static readonly FnDef[] _funciones =
    {
        new("Fecha", "DateDiffDay", "Días entre dos fechas: DateDiffDay(desde, hasta)"),
        new("Fecha", "DateDiffMonth", "Meses entre dos fechas"),
        new("Fecha", "DateDiffYear", "Años entre dos fechas"),
        new("Fecha", "AddDays", "Suma días a una fecha: AddDays(fecha, n)"),
        new("Fecha", "AddMonths", "Suma meses a una fecha"),
        new("Fecha", "AddYears", "Suma años a una fecha"),
        new("Texto", "Concat", "Concatena: Concat(a, b, ...)"),
        new("Texto", "Substring", "Substring(texto, inicio, largo)"),
        new("Texto", "Len", "Largo del texto"),
        new("Texto", "Upper", "Mayúsculas"),
        new("Texto", "Lower", "Minúsculas"),
        new("Texto", "Trim", "Quita espacios"),
        new("Lógicas", "Iif", "Iif(condición, siValor, siNo)"),
        new("Lógicas", "IsNull", "IsNull(valor, alternativo)"),
        new("Matemáticas", "Abs", "Valor absoluto"),
        new("Matemáticas", "Round", "Round(valor, decimales)"),
    };

    protected override void OnParametersSet()
    {
        // Recarga columnas si cambió la tabla; revalida.
        if (!string.Equals(_validatedTabla, Tabla, StringComparison.OrdinalIgnoreCase))
        {
            _validatedTabla = Tabla;
            var meta = string.IsNullOrWhiteSpace(Tabla) ? null : EntityCatalog.TryGet(Tabla);
            _columns = meta?.Columns.Where(c => !c.IsAudit).ToList() ?? (IReadOnlyList<ColumnMetadata>)Array.Empty<ColumnMetadata>();
        }
        Validate();
    }

    private async Task OnInput(ChangeEventArgs e)
    {
        Expression = e.Value?.ToString();
        await ExpressionChanged.InvokeAsync(Expression);
        Validate();
    }

    private async Task Insert(string snippet, int caretOffset)
    {
        _module ??= await JS.InvokeAsync<IJSObjectReference>("import", "./js/formula-editor.js");
        var nuevo = await _module.InvokeAsync<string?>("insertAtCursor", _ta, snippet, caretOffset);
        Expression = nuevo;
        await ExpressionChanged.InvokeAsync(Expression);
        Validate();
    }

    // Validación en vivo: parsea la expresión y verifica que sus columnas existan en la tabla.
    private void Validate()
    {
        _error = null;
        if (string.IsNullOrWhiteSpace(Expression)) return;
        var meta = string.IsNullOrWhiteSpace(Tabla) ? null : EntityCatalog.TryGet(Tabla);
        if (meta is null) { _error = "Elegí una tabla válida."; return; }
        try
        {
            var node = SgpaScalarTranslator.Translate(CriteriaOperator.Parse(Expression));
            foreach (var colName in ColumnasDe(node))
                if (!meta.Columns.Any(c => c.Name.Equals(colName, StringComparison.OrdinalIgnoreCase)
                                        || c.Property.Name.Equals(colName, StringComparison.OrdinalIgnoreCase)))
                { _error = $"La columna '{colName}' no existe en {meta.Table}."; return; }
        }
        catch (Exception ex) { _error = ex.Message; }
    }

    private static IEnumerable<string> ColumnasDe(ScalarNode node) => node switch
    {
        ScalarColumn c => new[] { c.Name },
        ScalarConst => Array.Empty<string>(),
        ScalarNegate u => ColumnasDe(u.Operand),
        ScalarBinary b => ColumnasDe(b.Left).Concat(ColumnasDe(b.Right)),
        ScalarCondition cn => ColumnasDe(cn.Left).Concat(ColumnasDe(cn.Right)),
        ScalarFunc f => f.Args.SelectMany(ColumnasDe),
        _ => Array.Empty<string>()
    };

    public async ValueTask DisposeAsync()
    {
        if (_module is not null)
        {
            try { await _module.DisposeAsync(); } catch { /* circuito ya cerrado */ }
        }
    }
}
