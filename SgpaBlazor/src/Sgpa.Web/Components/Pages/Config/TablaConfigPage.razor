@page "/config/tablas"
@rendermode InteractiveServer
@using Sgpa.Domain.Metadata
@using Sgpa.Data.Configuracion
@implements IDisposable
@inject ITablaConfigService Config
@inject WebCurrentUser CurrentUser
@inject NavigationManager Nav
@inject IToastNotificationService Toasts
@inject Sgpa.Web.State.UnsavedChangesService Unsaved

<PageTitle>Configuración de tablas</PageTitle>

<h3 class="mb-2">Configuración por tabla</h3>
<p class="text-muted">
    Settings dinámicos por tabla: <strong>edición inline</strong> (catálogos editables en la grilla),
    <strong>confirmación de borrado</strong> (exige tipear ELIMINAR) y <strong>auditoría</strong> de cambios por campo.
    El botón <strong>Columnas</strong> de cada fila abre el detalle de configuración por columna de esa tabla.
</p>

@if (!CurrentUser.IsAdmin)
{
    <div class="alert alert-warning">Esta configuración es sólo para administradores.</div>
}
else
{
    @* Toolbar: edición en memoria (las celdas marcan "pendiente"); se persiste todo junto al Guardar. *@
    <div class="d-flex align-items-center gap-2 mb-2">
        <DxButton Text="@(_dirty.Count > 0 ? $"Guardar ({_dirty.Count})" : "Guardar")" IconCssClass="fa-solid fa-floppy-disk"
                  RenderStyle="ButtonRenderStyle.Primary" Enabled="@(_dirty.Count > 0 && !_saving)" Click="GuardarAsync" />
        <DxButton Text="Descartar" IconCssClass="fa-solid fa-rotate-left" RenderStyle="ButtonRenderStyle.Secondary"
                  Enabled="@(_dirty.Count > 0 && !_saving)" Click="Descartar" />
        @if (_dirty.Count > 0)
        {
            <span class="text-muted small"><i class="fa-solid fa-pen me-1"></i>@_dirty.Count cambio(s) sin guardar</span>
        }
    </div>

    <DxGrid Data="_items" PageSize="25" ShowFilterRow="true" ShowSearchBox="true">
        <Columns>
            <DxGridDataColumn FieldName="Tabla" Caption="Tabla" Width="190px" />
            <DxGridDataColumn Caption="Alias (nombre amigable)" MinWidth="200">
                <CellDisplayTemplate Context="c">
                    @{ var vm = (Vm)c.DataItem; }
                    <DxTextBox Text="@vm.Alias" NullText="@vm.Tabla" SizeMode="SizeMode.Small"
                               TextChanged="@((string v) => { vm.Alias = v; MarkDirty(vm); })" />
                </CellDisplayTemplate>
            </DxGridDataColumn>
            <DxGridDataColumn Caption="Edición inline" Width="150px" TextAlignment="GridTextAlignment.Center">
                <HeaderCaptionTemplate>
                    @SelectAllHeader(context.Caption, v => v.Inline, (vm, b) => vm.Inline = b)
                </HeaderCaptionTemplate>
                <CellDisplayTemplate Context="c">
                    @{ var vm = (Vm)c.DataItem; }
                    <DxCheckBox Checked="vm.Inline" CheckedChanged="@((bool v) => { vm.Inline = v; MarkDirty(vm); })" />
                </CellDisplayTemplate>
            </DxGridDataColumn>
            <DxGridDataColumn Caption="Confirmar borrado" Width="170px" TextAlignment="GridTextAlignment.Center">
                <HeaderCaptionTemplate>
                    @SelectAllHeader(context.Caption, v => v.Confirmar, (vm, b) => vm.Confirmar = b)
                </HeaderCaptionTemplate>
                <CellDisplayTemplate Context="c">
                    @{ var vm = (Vm)c.DataItem; }
                    <DxCheckBox Checked="vm.Confirmar" CheckedChanged="@((bool v) => { vm.Confirmar = v; MarkDirty(vm); })" />
                </CellDisplayTemplate>
            </DxGridDataColumn>
            <DxGridDataColumn Caption="Auditar" Width="120px" TextAlignment="GridTextAlignment.Center">
                <HeaderCaptionTemplate>
                    @SelectAllHeader(context.Caption, v => v.Auditar, (vm, b) => vm.Auditar = b)
                </HeaderCaptionTemplate>
                <CellDisplayTemplate Context="c">
                    @{ var vm = (Vm)c.DataItem; }
                    <DxCheckBox Checked="vm.Auditar" CheckedChanged="@((bool v) => { vm.Auditar = v; MarkDirty(vm); })" />
                </CellDisplayTemplate>
            </DxGridDataColumn>
            <DxGridDataColumn Caption="Disponible p/ reportes" Width="170px" TextAlignment="GridTextAlignment.Center">
                <HeaderCaptionTemplate>
                    @SelectAllHeader(context.Caption, v => v.Disponible, (vm, b) => vm.Disponible = b)
                </HeaderCaptionTemplate>
                <CellDisplayTemplate Context="c">
                    @{ var vm = (Vm)c.DataItem; }
                    <DxCheckBox Checked="vm.Disponible" CheckedChanged="@((bool v) => { vm.Disponible = v; MarkDirty(vm); })" />
                </CellDisplayTemplate>
            </DxGridDataColumn>
            @* Acción por fila: abre la configuración por columna de esta tabla (evita un ítem de menú suelto). *@
            <DxGridDataColumn Caption="Columnas" Width="120px" TextAlignment="GridTextAlignment.Center">
                <CellDisplayTemplate Context="c">
                    @{ var vm = (Vm)c.DataItem; }
                    <DxButton Text="Columnas" IconCssClass="fa-solid fa-table-columns" RenderStyle="ButtonRenderStyle.Link"
                              Click="@(() => Nav.NavigateTo($"/config/columnas?tabla={Uri.EscapeDataString(vm.Tabla)}"))" />
                </CellDisplayTemplate>
            </DxGridDataColumn>
        </Columns>
    </DxGrid>
}

@code {
    private List<Vm> _items = new();

    protected override async Task OnInitializedAsync()
    {
        await CurrentUser.EnsureLoadedAsync();
        if (!CurrentUser.IsAdmin) return;

        await Config.EnsureLoadedAsync();
        _items = EntityCatalog.CrudCapable
            .Select(m => m.Table)
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .OrderBy(t => t, StringComparer.OrdinalIgnoreCase)
            .Select(t =>
            {
                var c = Config.Get(t);
                return new Vm { Tabla = t, Alias = c.Alias, Inline = c.EdicionInline, Confirmar = c.ConfirmarBorrado, Auditar = c.Auditar, Disponible = Config.DisponibleReportes(t) };
            })
            .ToList();
    }

    private readonly HashSet<Vm> _dirty = new();
    private bool _saving;

    private static TablaConfig ToConfig(Vm vm)
        => new(vm.Inline, vm.Confirmar, vm.Auditar,
               string.IsNullOrWhiteSpace(vm.Alias) ? null : vm.Alias.Trim(), vm.Disponible);

    // Edición en memoria: marca la fila como pendiente; se persiste todo junto al Guardar.
    private void MarkDirty(Vm vm)
    {
        _dirty.Add(vm);
        SyncDirty();
    }

    // Refleja el estado de cambios pendientes en el guard global (UnsavedChangesGuard) y re-renderiza.
    private void SyncDirty()
    {
        Unsaved.Set(this, _dirty.Count > 0);
        StateHasChanged();
    }

    public void Dispose() => Unsaved.Clear(this);

    private async Task GuardarAsync()
    {
        if (_dirty.Count == 0 || _saving) return;
        _saving = true;
        try
        {
            var pendientes = _dirty.Select(vm => new KeyValuePair<string, TablaConfig>(vm.Tabla, ToConfig(vm))).ToList();
            await Config.SetManyAsync(pendientes);
            _dirty.Clear();
            SyncDirty();
            Toasts.Exito($"Configuración guardada ({pendientes.Count} tabla(s)).");
        }
        finally { _saving = false; }
    }

    // Descarta los cambios pendientes volviendo cada fila a su valor guardado (desde la cache del servicio).
    private void Descartar()
    {
        foreach (var vm in _dirty)
        {
            var c = Config.Get(vm.Tabla);
            vm.Alias = c.Alias;
            vm.Inline = c.EdicionInline;
            vm.Confirmar = c.ConfirmarBorrado;
            vm.Auditar = c.Auditar;
            vm.Disponible = Config.DisponibleReportes(vm.Tabla);
        }
        _dirty.Clear();
        SyncDirty();
    }

    // Cabezal con checkbox "marcar/desmarcar todas" para una columna booleana. stopPropagation evita que el clic
    // en el checkbox dispare el ordenamiento de la columna.
    private RenderFragment SelectAllHeader(string caption, Func<Vm, bool> getter, Action<Vm, bool> setter) =>
        @<div class="d-flex align-items-center justify-content-center gap-1">
            <span @onclick:stopPropagation="true">
                <DxCheckBox Checked="@HeaderState(getter)" AllowIndeterminateStateByClick="false"
                            CheckedChanged="@((bool? v) => SetAll(getter, setter, v == true))"
                            Tooltip="Marcar/desmarcar en todas las tablas" />
            </span>
            <span>@caption</span>
        </div>;

    // Estado del check del cabezal: todas marcadas → marcado; ninguna → desmarcado; mezcla → indeterminado.
    private bool? HeaderState(Func<Vm, bool> getter)
        => _items.Count == 0 ? false
           : _items.All(getter) ? true
           : _items.Any(getter) ? (bool?)null
           : false;

    // Aplica el valor a TODAS las tablas en memoria, marcando como pendientes sólo las filas que cambian.
    private void SetAll(Func<Vm, bool> getter, Action<Vm, bool> setter, bool value)
    {
        foreach (var vm in _items.Where(vm => getter(vm) != value))
        {
            setter(vm, value);
            _dirty.Add(vm);
        }
        SyncDirty();
    }

    public sealed class Vm
    {
        public string Tabla { get; set; } = string.Empty;
        public string? Alias { get; set; }
        public bool Inline { get; set; }
        public bool Confirmar { get; set; }
        public bool Auditar { get; set; }
        public bool Disponible { get; set; }
    }
}
