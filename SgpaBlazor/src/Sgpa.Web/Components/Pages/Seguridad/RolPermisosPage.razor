@page "/seguridad/roles/{RolId:int}/permisos"
@rendermode InteractiveServer
@using Sgpa.Data.Configuracion
@using Sgpa.Data.Security.Admin
@using Sgpa.Domain.Metadata
@using Sgpa.Domain.Security
@inject ISeguridadAdminService Admin
@inject ITablaConfigService TablaConfig
@inject WebCurrentUser CurrentUser
@inject IToastNotificationService Toasts
@inject NavigationManager Nav
@inject Sgpa.Web.State.UnsavedChangesService Unsaved
@implements IDisposable

<PageTitle>Seguridad · Permisos del rol</PageTitle>

@if (_denied)
{
    <div class="alert alert-danger mt-3">Solo un administrador puede gestionar permisos.</div>
}
else if (_rol is null)
{
    <div class="alert alert-warning mt-3">El rol indicado no existe. <a href="/seguridad/roles">Volver a roles</a>.</div>
}
else
{
    <div class="d-flex align-items-center gap-2 mb-2">
        <a href="/seguridad/roles" class="btn btn-sm btn-outline-secondary"><i class="fa-solid fa-arrow-left"></i></a>
        <h3 class="mb-0"><i class="fa-solid fa-shield-halved me-2 text-primary"></i>Permisos · @_rol.Nombre</h3>
    </div>

    @if (_rol.EsAdmin)
    {
        <div class="alert alert-info">Este rol es <strong>administrador</strong>: tiene acceso total y omite todos los permisos (tabla, campo y registro).</div>
    }
    else
    {
        <p class="text-muted small mb-2">
            Cada fila es una tabla. <strong>Expandí</strong> (▸) para editar en el detalle las acciones permitidas,
            las restricciones por <strong>campo</strong> y los filtros por <strong>registro</strong>.
        </p>

        @* Las acciones masivas editan en memoria; se confirman con Guardar (Ctrl+S). Las restricciones por campo
           y las acciones por tabla del detalle se guardan desde el propio detalle. *@
        <SgpaShortcuts OnSave="GuardarAsync" CanSave="@(() => _dirty.Count > 0 && !_saving)" />
        <div class="mb-3 d-flex flex-wrap align-items-center gap-2">
            <DxButton Text="@(_dirty.Count > 0 ? $"Guardar ({_dirty.Count})" : "Guardar")" IconCssClass="fa-solid fa-floppy-disk"
                      RenderStyle="ButtonRenderStyle.Primary" SizeMode="SizeMode.Small"
                      Enabled="@(_dirty.Count > 0 && !_saving)" Click="GuardarAsync" />
            <DxButton Text="Descartar" IconCssClass="fa-solid fa-rotate-left" RenderStyle="ButtonRenderStyle.Secondary"
                      SizeMode="SizeMode.Small" Enabled="@(_dirty.Count > 0 && !_saving)" Click="Descartar" />
            <span class="vr"></span>
            <DxButton Text="Sólo lectura a todas" RenderStyle="ButtonRenderStyle.Secondary" SizeMode="SizeMode.Small" Click="@(() => SetTodas(PermissionAction.Read))" />
            <DxButton Text="Acceso total a todas" RenderStyle="ButtonRenderStyle.Secondary" SizeMode="SizeMode.Small" Click="@(() => SetTodas(PermissionAction.All))" />
            <DxButton Text="Quitar todo" RenderStyle="ButtonRenderStyle.Secondary" SizeMode="SizeMode.Small" Click="@(() => SetTodas(PermissionAction.None))" />
            @if (_dirty.Count > 0)
            {
                <span class="text-muted small"><i class="fa-solid fa-pen me-1"></i>@_dirty.Count tabla(s) sin guardar</span>
            }
        </div>

        <DxGrid Data="_items" PageSize="30" ShowSearchBox="true" CssClass="sgpa-grid"
                DetailRowDisplayMode="GridDetailRowDisplayMode.Auto">
            <Columns>
                <DxGridDataColumn FieldName="Display" Caption="Tabla" MinWidth="240">
                    <CellDisplayTemplate Context="c">
                        @{ var vm = (PermisoTablaVm)c.DataItem; }
                        <span>@vm.Display</span> <span class="text-muted small">@vm.Tabla</span>
                    </CellDisplayTemplate>
                </DxGridDataColumn>
                <DxGridDataColumn Caption="Permisos" Width="200px" TextAlignment="GridTextAlignment.Left">
                    <CellDisplayTemplate Context="c">
                        @{ var vm = (PermisoTablaVm)c.DataItem; }
                        @Badge("L", "Leer", vm.Has(PermissionAction.Read))
                        @Badge("C", "Crear", vm.Has(PermissionAction.Create))
                        @Badge("M", "Modificar", vm.Has(PermissionAction.Write))
                        @Badge("B", "Borrar", vm.Has(PermissionAction.Delete))
                    </CellDisplayTemplate>
                </DxGridDataColumn>
            </Columns>
            <DetailRowTemplate Context="c">
                @{ var vm = (PermisoTablaVm)c.DataItem; }
                <RolTablaPermisoDetalle RolId="RolId" Tabla="@vm.Tabla" Vm="vm" OnAccionesChanged="@(() => OnDetalleGuardado(vm))" />
            </DetailRowTemplate>
        </DxGrid>
    }
}

@code {
    [Parameter] public int RolId { get; set; }

    private bool _denied;
    private RolAdmin? _rol;
    private List<PermisoTablaVm> _items = new();

    protected override async Task OnInitializedAsync()
    {
        await CurrentUser.EnsureLoadedAsync();
        if (!CurrentUser.IsAdmin) { _denied = true; return; }

        var roles = await Admin.ListRolesAsync();
        _rol = roles.FirstOrDefault(r => r.Id == RolId);
        if (_rol is null || _rol.EsAdmin) return;

        await TablaConfig.EnsureLoadedAsync();

        var permisos = (await Admin.ListPermisosAsync(RolId))
            .ToDictionary(p => p.Tabla, p => p.Acciones, StringComparer.OrdinalIgnoreCase);

        _items = EntityCatalog.CrudCapable
            .Select(m => m.Table)
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .Select(t => new PermisoTablaVm
            {
                Tabla = t,
                Display = TablaConfig.DisplayName(t),
                Acciones = permisos.TryGetValue(t, out var a) ? a : PermissionAction.None
            })
            .OrderBy(v => v.Display, StringComparer.OrdinalIgnoreCase)
            .ToList();

        // Baseline del estado guardado (acciones por tabla) para detectar/descartar los cambios masivos pendientes.
        _accionesBase = _items.ToDictionary(v => v.Tabla, v => v.Acciones, StringComparer.OrdinalIgnoreCase);
    }

    // ---- Unit-of-work de las acciones masivas (las acciones por tabla / campos del detalle se guardan ahí) ----
    private readonly HashSet<PermisoTablaVm> _dirty = new();
    private Dictionary<string, PermissionAction> _accionesBase = new(StringComparer.OrdinalIgnoreCase);
    private bool _saving;

    // Aplica una acción a TODAS las tablas en memoria, marcando como pendientes sólo las que cambian.
    private void SetTodas(PermissionAction acciones)
    {
        foreach (var vm in _items.Where(vm => vm.Acciones != acciones))
        {
            vm.Acciones = acciones;
            _dirty.Add(vm);
        }
        SyncDirty();
    }

    private async Task GuardarAsync()
    {
        if (_dirty.Count == 0 || _saving) return;
        _saving = true;
        try
        {
            var pend = _dirty.ToList();
            foreach (var vm in pend)
            {
                await Admin.SetPermisoAsync(RolId, vm.Tabla, vm.Acciones);
                _accionesBase[vm.Tabla] = vm.Acciones;
            }
            _dirty.Clear();
            SyncDirty();
            Toasts.Exito($"Permisos guardados ({pend.Count} tabla(s)).");
        }
        finally { _saving = false; }
    }

    private void Descartar()
    {
        foreach (var vm in _dirty)
            if (_accionesBase.TryGetValue(vm.Tabla, out var a)) vm.Acciones = a;
        _dirty.Clear();
        SyncDirty();
    }

    // El detalle de una tabla guardó sus acciones por su cuenta: sincronizamos el baseline y la sacamos de pendientes.
    private void OnDetalleGuardado(PermisoTablaVm vm)
    {
        _accionesBase[vm.Tabla] = vm.Acciones;
        _dirty.Remove(vm);
        SyncDirty();
    }

    private void SyncDirty()
    {
        Unsaved.Set(this, _dirty.Count > 0);
        StateHasChanged();
    }

    public void Dispose() => Unsaved.Clear(this);

    // Pastilla compacta de una acción: resaltada si está concedida, atenuada si no.
    private RenderFragment Badge(string letra, string titulo, bool on) =>
        @<span class="badge me-1 @(on ? "bg-success" : "bg-light text-muted border")" title="@titulo">@letra</span>;
}
