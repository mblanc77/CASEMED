@page "/reportes/sql"
@rendermode InteractiveServer
@using Sgpa.Data.Reporting
@inject IReporteSqlService Reportes
@inject WebCurrentUser CurrentUser
@inject IToastNotificationService Toasts
@inject NavigationManager Nav

<PageTitle>Reportes SQL</PageTitle>
@* Atajo: Alt+N = nuevo reporte SQL. *@
<SgpaShortcuts OnNew="@(() => Nav.NavigateTo("/reportes/sql/editor"))" />

@if (_denied)
{
    <div class="alert alert-danger mt-3">Solo un administrador puede administrar los reportes SQL.</div>
}
else
{
    <div class="d-flex align-items-center gap-2 mb-3">
        <h3 class="mb-0"><i class="fa-solid fa-database me-2 text-primary"></i>Reportes SQL</h3>
        <DxButton Text="Nuevo reporte SQL" IconCssClass="fa-solid fa-plus" RenderStyle="ButtonRenderStyle.Primary"
                  CssClass="ms-auto" Click="@(() => Nav.NavigateTo("/reportes/sql/editor"))" />
    </div>

    @if (_reportes.Count == 0)
    {
        <p class="text-muted">No hay reportes SQL creados todavía.</p>
    }
    else
    {
        <table class="table table-sm table-hover align-middle">
            <thead>
                <tr>
                    <th>Nombre</th>
                    <th style="width:120px">Acceso</th>
                    <th style="width:160px">Modificado</th>
                    <th style="width:90px">Autor</th>
                    <th style="width:220px"></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var r in _reportes)
                {
                    <tr>
                        <td>@r.Nombre</td>
                        <td class="text-muted small">@(r.SoloAdmin ? "Sólo admin" : "Todos")</td>
                        <td class="text-muted small">@r.Fecha.ToString("dd/MM/yyyy HH:mm")</td>
                        <td class="text-muted small">@r.Login</td>
                        <td class="text-nowrap">
                            <DxButton Text="Ver" IconCssClass="fa-solid fa-eye" RenderStyle="ButtonRenderStyle.Link"
                                      Click="@(() => Nav.NavigateTo($"/reportes/sql/{r.Id}"))" />
                            <DxButton Text="Editar" IconCssClass="fa-solid fa-pen" RenderStyle="ButtonRenderStyle.Link"
                                      Click="@(() => Nav.NavigateTo($"/reportes/sql/editor/{r.Id}"))" />
                            <DxButton Text="Borrar" IconCssClass="fa-solid fa-trash" RenderStyle="ButtonRenderStyle.Link"
                                      Click="@(() => OpenDelete(r))" />
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }

    <DxPopup @bind-Visible="_deleteVisible" HeaderText="Borrar reporte" Width="480px" CloseOnEscape="true">
        <BodyContentTemplate>
            <p>¿Borrar el reporte <strong>@_target?.Nombre</strong>? Dejará de aparecer en el menú.</p>
            <div class="d-flex gap-2 justify-content-end">
                <DxButton Text="Cancelar" RenderStyle="ButtonRenderStyle.Secondary" Click="@(() => _deleteVisible = false)" />
                <DxButton Text="Borrar" IconCssClass="fa-solid fa-trash" RenderStyle="ButtonRenderStyle.Danger" Click="DeleteAsync" />
            </div>
        </BodyContentTemplate>
    </DxPopup>
}

@code {
    private bool _denied;
    private IReadOnlyList<ReporteSqlInfo> _reportes = Array.Empty<ReporteSqlInfo>();
    private bool _deleteVisible;
    private ReporteSqlInfo? _target;

    protected override async Task OnInitializedAsync()
    {
        await CurrentUser.EnsureLoadedAsync();
        if (!CurrentUser.IsAdmin) { _denied = true; return; }
        await ReloadAsync();
    }

    private async Task ReloadAsync() => _reportes = await Reportes.AllAsync();

    private void OpenDelete(ReporteSqlInfo r) { _target = r; _deleteVisible = true; }

    private async Task DeleteAsync()
    {
        if (_target is null) return;
        await Reportes.DeleteAsync(_target.Id);
        _deleteVisible = false;
        Toasts.Exito("Reporte borrado.");
        await ReloadAsync();
    }
}
