@page "/reportes/din/{Id:int}"
@rendermode InteractiveServer
@using System.Collections.Generic
@using DevExpress.Data.Filtering
@using Sgpa.Data
@using Sgpa.Data.Crud
@using Sgpa.Data.Reporting
@using Sgpa.Domain.Metadata
@using Sgpa.Domain.Security
@using Sgpa.Web.Components.Crud
@inject IReporteDinamicoService Reportes
@inject IDbExecutor Db
@inject WebCurrentUser CurrentUser
@inject IToastNotificationService Toasts
@inject ICalculatedFieldCatalog CalcCatalog

<PageTitle>@(_rep?.Nombre ?? "Reporte")</PageTitle>

@if (_notFound)
{
    <div class="alert alert-warning mt-3">El reporte solicitado no existe.</div>
}
else if (_denied)
{
    <div class="alert alert-danger mt-3">
        No tenés permiso para ver este reporte. Faltan permisos de lectura sobre:
        <strong>@string.Join(", ", _missingTables)</strong>.
    </div>
}
else if (_rep is not null)
{
    <h3 class="mb-3"><i class="fa-solid fa-file-lines me-2"></i>@_rep.Nombre</h3>

    @if (_promptDefs.Count > 0 && !_ran)
    {
        @* Pedir parámetros antes de mostrar los datos (estilo Request Parameters). *@
        <div class="card" style="max-width:640px">
            <div class="card-header py-2">Parámetros</div>
            <div class="card-body">
                <ParametrosPrompt Defs="_promptDefs" Initial="_lastValues" AcceptText="Ver reporte"
                                  OnAccept="OnParamsAccepted" />
            </div>
        </div>
    }
    else
    {
        <SgpaReportGrid Rows="_rows" Columns="@GridColumns()" Summaries="_summaries"
                        ViewKey="@($"rptdin:{Id}")" ReportName="@_rep.Nombre" Truncated="_truncated">
            <ToolbarStart>
                @if (_promptDefs.Count > 0)
                {
                    <DxButton Text="Cambiar parámetros" IconCssClass="fa-solid fa-sliders"
                              RenderStyle="ButtonRenderStyle.Secondary" Click="@(() => _ran = false)" />
                }
            </ToolbarStart>
        </SgpaReportGrid>
    }
}

@code {
    [Parameter] public int Id { get; set; }

    private ReporteDinamico? _rep;
    private ReporteDinamicoDef _def = new();
    private EntityMetadata? _root;
    private bool _notFound, _denied, _ran, _truncated;
    private readonly List<string> _missingTables = new();

    private IReadOnlyList<FiltroParametroDef> _promptDefs = Array.Empty<FiltroParametroDef>();
    private IReadOnlyDictionary<string, object?>? _lastValues;

    private IReadOnlyList<CalculatedField> _rootCalc = Array.Empty<CalculatedField>();
    private List<object> _rows = new();
    private IReadOnlyList<ReportColumn> _columns = Array.Empty<ReportColumn>();
    private List<(string FieldName, DevExpress.Blazor.GridSummaryItemType Type)> _summaries = new();

    // Columnas para la grilla compartida (con el índice de agrupamiento inicial de la definición).
    private IReadOnlyList<SgpaReportGrid.ReportGridColumn> GridColumns()
        => _columns.Select(c => new SgpaReportGrid.ReportGridColumn(
            c.FieldName, c.Caption, c.DisplayFormat, c.ClrType, GroupIndex(c.FieldName))).ToList();

    protected override async Task OnParametersSetAsync()
    {
        _notFound = _denied = _ran = _truncated = false;
        _missingTables.Clear();

        _rep = await Reportes.GetAsync(Id);
        if (_rep is null) { _notFound = true; return; }
        _def = _rep.Def;
        _root = EntityCatalog.TryGet(_def.RootTable);
        if (_root is null) { _notFound = true; return; }

        await CalcCatalog.EnsureLoadedAsync();
        _rootCalc = CalcCatalog.For(_def.RootTable);

        // Seguridad: lectura sobre TODAS las tablas involucradas (raíz + destinos N-1 + relaciones del filtro).
        await CurrentUser.EnsureLoadedAsync();
        var filterForTables = Translate(ParseCriteria());
        foreach (var tabla in DynamicReportQueryBuilder.InvolvedTables(_def, filterForTables, _rootCalc))
            if (!CurrentUser.Can(tabla, PermissionAction.Read))
                _missingTables.Add(tabla);
        if (_missingTables.Count > 0) { _denied = true; return; }

        _promptDefs = FiltroParametros.DeserializarDefs(_def.ParametrosJson);
        // Red de seguridad: si el criterio referencia parámetros pero no hay defs (p. ej. un reporte guardado antes
        // de preservarlos), se sintetizan prompts de texto a partir de los nombres del criterio para no quedar
        // pidiendo nada y mostrando vacío.
        if (_promptDefs.Count == 0)
        {
            var nombres = FiltroParametros.Nombres(ParseCriteria());
            if (nombres.Count > 0)
                _promptDefs = nombres.Select(n => new FiltroParametroDef(n, n, "System.String", null, null)).ToList();
        }
        if (_promptDefs.Count == 0)
            await RunAsync(null);   // sin parámetros: ejecutar directo
    }

    private CriteriaOperator? ParseCriteria()
        => string.IsNullOrWhiteSpace(_def.Criteria) ? null : CriteriaOperator.Parse(_def.Criteria);

    private FilterNode? Translate(CriteriaOperator? crit)
        => SgpaCriteriaTranslator.Translate(crit, prefix => EntityRelations.ByPrefix(_root!.EntityType, prefix));

    private async Task OnParamsAccepted(IReadOnlyDictionary<string, object?> vals)
    {
        _lastValues = vals;
        await RunAsync(vals);
    }

    private async Task RunAsync(IReadOnlyDictionary<string, object?>? paramValues)
    {
        try
        {
            var crit = ParseCriteria();
            if (paramValues is not null) crit = FiltroParametros.Sustituir(crit, paramValues);
            var query = DynamicReportQueryBuilder.Build(_def, Translate(crit), rootCalc: _rootCalc);

            var rows = await Db.QueryAsync<dynamic>(query.Sql, query.Parameters);
            // DxGrid resuelve los FieldName de columnas dinámicas contra los miembros de un ExpandoObject
            // (un Dictionary plano lo trata como objeto y busca propiedades → "property not found").
            _rows = rows.Select(r =>
            {
                IDictionary<string, object?> ex = new System.Dynamic.ExpandoObject();
                foreach (var kv in (IDictionary<string, object>)r) ex[kv.Key] = kv.Value;
                return (object)ex;
            }).ToList();
            _columns = query.Columns;
            _summaries = BuildSummaries();
            _truncated = _rows.Count >= DynamicReportQueryBuilder.DefaultMaxRows;
            _ran = true;
        }
        catch (Exception ex)
        {
            Toasts.Error($"No se pudo ejecutar el reporte: {ex.Message}");
        }
    }

    // GroupIndex de una columna de salida según el orden de def.Groups (o -1 si no agrupa).
    private int GroupIndex(string fieldName)
    {
        for (int i = 0; i < _def.Groups.Count; i++)
            if (FieldNameOf(_def.Groups[i]).Equals(fieldName, StringComparison.OrdinalIgnoreCase))
                return i;
        return -1;
    }

    private List<(string, DevExpress.Blazor.GridSummaryItemType)> BuildSummaries()
    {
        var list = new List<(string, DevExpress.Blazor.GridSummaryItemType)>();
        foreach (var s in _def.Summaries)
            list.Add((FieldNameOf(s.Field), s.Agg switch
            {
                AggKind.Sum => DevExpress.Blazor.GridSummaryItemType.Sum,
                AggKind.Min => DevExpress.Blazor.GridSummaryItemType.Min,
                AggKind.Max => DevExpress.Blazor.GridSummaryItemType.Max,
                AggKind.Avg => DevExpress.Blazor.GridSummaryItemType.Avg,
                _ => DevExpress.Blazor.GridSummaryItemType.Count
            }));
        return list;
    }

    // Empareja un ReportFieldRef (grupo/sumario) con el FieldName de la columna de salida correspondiente.
    private string FieldNameOf(ReportFieldRef field)
    {
        var idx = -1;
        for (int i = 0; i < _def.Columns.Count; i++)
            if (_def.Columns[i].Column.Equals(field.Column, StringComparison.OrdinalIgnoreCase)
                && _def.Columns[i].Path.SequenceEqual(field.Path, StringComparer.OrdinalIgnoreCase))
            { idx = i; break; }
        return idx >= 0 && idx < _columns.Count ? _columns[idx].FieldName : field.Column;
    }
}
