@page "/pagos/carga-liquido"
@rendermode InteractiveServer
@using DevExpress.Blazor
@using Sgpa.Business.Pagos
@using Sgpa.Data.Errors
@using Sgpa.Web.Controllers
@using Microsoft.Extensions.Caching.Memory
@inject ImpLiquidoService Liquidos
@inject IMemoryCache Cache
@inject IToastNotificationService Toasts

@*
    Carga automática de líquidos (port de frmCargaLiquido, app VB6 "SP"). Se elige empresa + mes/año y se sube un
    archivo CSV con la cédula y el importe líquido (por defecto columnas 1 y 2). Al cargar, se reemplazan los
    líquidos previos de esa empresa/mes y se reinsertan resolviendo el empleo (SP_Trabaja). Alternativa masiva a
    la carga manual de /pagos/imp-liquido.
*@

<PageTitle>Carga de líquidos (archivo)</PageTitle>

<h3 class="mb-3"><i class="fa-solid fa-file-import me-2 text-primary"></i>Carga automática de líquidos</h3>

<div class="card mb-3" style="max-width: 820px;">
    <div class="card-body">
        <DxFormLayout>
            <DxFormLayoutItem Caption="Empresa" ColSpanMd="12">
                <DxComboBox Data="_empresas" @bind-Value="_codEmpresa" TData="EmpresaTrabaja" TValue="int?"
                            ValueFieldName="@nameof(EmpresaTrabaja.CodEmpresa)" TextFieldName="@nameof(EmpresaTrabaja.DescEmpresa)"
                            FilteringMode="DataGridFilteringMode.Contains" NullText="Elegí la empresa…" />
            </DxFormLayoutItem>
            <DxFormLayoutItem Caption="Mes" ColSpanMd="3"><DxSpinEdit @bind-Value="_mes" MinValue="1" MaxValue="12" /></DxFormLayoutItem>
            <DxFormLayoutItem Caption="Año" ColSpanMd="3"><DxSpinEdit @bind-Value="_anio" MinValue="2000" MaxValue="2100" /></DxFormLayoutItem>
            <DxFormLayoutItem Caption="Col. cédula" ColSpanMd="3"><DxSpinEdit @bind-Value="_colCI" MinValue="1" MaxValue="50" /></DxFormLayoutItem>
            <DxFormLayoutItem Caption="Col. importe" ColSpanMd="3"><DxSpinEdit @bind-Value="_colImp" MinValue="1" MaxValue="50" /></DxFormLayoutItem>
            <DxFormLayoutItem Caption="Archivo (CSV)" ColSpanMd="12">
                <div id="liq-dropzone" class="sgpa-dropzone">
                    <i class="fa-solid fa-cloud-arrow-up sgpa-dropzone__icon"></i>
                    <span class="sgpa-dropzone__hint">Arrastrá el archivo .csv/.txt acá o</span>
                    <DxUpload Name="file" UploadUrl="@_uploadUrl"
                              ExternalDropZoneCssSelector="#liq-dropzone"
                              ExternalDropZoneDragOverCssClass="sgpa-dropzone--over"
                              AllowMultiFileUpload="false"
                              AllowedFileExtensions="@_extensiones"
                              MaxFileSize="16777216"
                              FileUploaded="OnFileUploaded" />
                </div>
                @if (_fileName is not null)
                {
                    <small class="text-muted">@_fileName</small>
                }
            </DxFormLayoutItem>
        </DxFormLayout>

        <div class="d-flex justify-content-end gap-2 mt-3">
            <DxButton Text="Analizar" IconCssClass="fa-solid fa-magnifying-glass-chart" RenderStyle="ButtonRenderStyle.Secondary"
                      Click="Analizar" Enabled="@(_contenido is not null && !_procesando)" />
            <DxButton Text="Cargar" IconCssClass="fa-solid fa-file-import" RenderStyle="ButtonRenderStyle.Primary"
                      Click="@(() => _confirmar = true)" Enabled="@(_parse is not null && _parse.Filas.Count > 0 && _codEmpresa is not null && !_procesando)" />
        </div>
    </div>
</div>

@if (_parse is not null)
{
    <div class="card mb-3" style="max-width: 820px;">
        <div class="card-body">
            <h5 class="card-title">Análisis del archivo</h5>
            <p class="mb-0">
                Filas válidas: <strong>@_parse.Filas.Count</strong> ·
                Ignoradas (encabezado/sin cédula): <strong>@_parse.Ignoradas</strong>
            </p>
            @if (_parse.Filas.Count > 0)
            {
                <small class="text-muted">Ej.: @string.Join(", ", _parse.Filas.Take(3).Select(f => $"{f.CI}={f.Importe:N2}"))…</small>
            }
        </div>
    </div>
}

@if (_result is not null)
{
    <div class="card" style="max-width: 820px;">
        <div class="card-body">
            <h5 class="card-title text-success">Carga realizada</h5>
            <p class="mb-1">
                Cédulas cargadas: <strong>@_result.CedulasCargadas</strong> ·
                Filas SP_ImpLiquido: <strong>@_result.Filas</strong> ·
                Sin empleo en la empresa: <strong class="@(_result.SinEmpleo.Count > 0 ? "text-warning" : "")">@_result.SinEmpleo.Count</strong>
            </p>
            @if (_result.SinEmpleo.Count > 0)
            {
                <small class="text-muted">No se cargaron (sin empleo en la empresa): @string.Join(", ", _result.SinEmpleo.Take(30))@(_result.SinEmpleo.Count > 30 ? "…" : "")</small>
            }
        </div>
    </div>
}

<DxPopup @bind-Visible="_confirmar" HeaderText="Confirmar carga" Width="480px" CloseOnEscape="true">
    <BodyContentTemplate>
        <p>
            ¿Cargar @_parse?.Filas.Count líquido(s) para
            <strong>@(_empresas.FirstOrDefault(e => e.CodEmpresa == _codEmpresa)?.DescEmpresa)</strong>,
            período <strong>@_mes.ToString("00")/@_anio</strong>?
        </p>
        <p class="text-muted mb-0">Los líquidos previos de esa empresa/mes serán reemplazados.</p>
        <div class="d-flex justify-content-end gap-2 mt-3">
            <DxButton Text="Cancelar" RenderStyle="ButtonRenderStyle.Secondary" Click="@(() => _confirmar = false)" Enabled="@(!_procesando)" />
            <DxButton Text="Sí, cargar" RenderStyle="ButtonRenderStyle.Primary" Click="CargarAsync" Enabled="@(!_procesando)" />
        </div>
    </BodyContentTemplate>
</DxPopup>

@code {
    private IReadOnlyList<EmpresaTrabaja> _empresas = Array.Empty<EmpresaTrabaja>();
    private int? _codEmpresa;
    private int _mes = DateTime.Today.Month;
    private int _anio = DateTime.Today.Year;
    private int _colCI = 1;
    private int _colImp = 2;

    private readonly List<string> _extensiones = new() { ".csv", ".txt" };
    private string _token = "";
    private string _uploadUrl = "";

    private string? _contenido;
    private string? _fileName;
    private LiquidoParse? _parse;
    private CargaLiquidoResult? _result;
    private bool _procesando, _confirmar;

    protected override async Task OnInitializedAsync()
    {
        _empresas = await Liquidos.GetTodasEmpresasAsync();
        NuevoToken();
    }

    private void NuevoToken()
    {
        _token = Guid.NewGuid().ToString("N");
        _uploadUrl = $"/pagos/carga-liquido/upload?token={_token}";
    }

    private void OnFileUploaded(FileUploadEventArgs e)
    {
        if (Cache.TryGetValue(CargaLiquidoController.CacheKey(_token), out LiquidoUpload? up) && up is not null)
        {
            _fileName = up.FileName;
            _contenido = up.Contenido;
        }
        else
        {
            _contenido = null;
            _fileName = null;
            Toasts.Error("No se pudo leer el archivo subido.");
        }
        _parse = null;
        _result = null;
    }

    private void Analizar()
    {
        if (_contenido is null) return;
        _result = null;
        _parse = LiquidoCsvParser.Parse(_contenido, _colCI - 1, _colImp - 1);
        if (_parse.Filas.Count == 0)
            Toasts.Aviso("No se encontraron filas con cédula e importe válidos. Revisá las columnas.");
    }

    private async Task CargarAsync()
    {
        if (_parse is null || _codEmpresa is null) return;
        _procesando = true;
        try
        {
            _result = await Liquidos.CargarMasivoAsync(_codEmpresa.Value, _mes, _anio, _parse.Filas);
            _confirmar = false;
            Toasts.Exito($"Líquidos cargados: {_result.CedulasCargadas} cédula(s) para {_mes:00}/{_anio}.");
            _contenido = null;
            _fileName = null;
            _parse = null;
            NuevoToken();
        }
        catch (Exception ex)
        {
            Toasts.Error(SqlErrorMessages.Amigable(ex));
        }
        finally
        {
            _procesando = false;
        }
    }
}
