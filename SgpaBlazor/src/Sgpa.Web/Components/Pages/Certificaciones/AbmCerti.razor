@page "/certificaciones"
@page "/certificaciones/nuevo"
@page "/certificaciones/{NroLlamado:int}"
@rendermode InteractiveServer
@using Sgpa.Domain.Entities
@using Sgpa.Data.Crud
@using Sgpa.Web.Components.Crud
@using Sgpa.Business.Certificaciones
@inject CertificacionService Certi
@inject ISgpaLookupService Lookups

<PageTitle>Certificaciones</PageTitle>

<SgpaMasterDetailView TMaster="Certificacion" BaseRoute="/certificaciones"
                      TitlePlural="Certificaciones" TitleSingular="la certificación" NewLabel="Nueva certificación"
                      ReportesEntidad="Certificacion"
                      ValidateAsync="@(c => Certi.ValidarAsync(c))"
                      GetWarningsAsync="@(c => Certi.GetAvisosDiasAsync(c))"
                      OnNewAsync="@(async c => c.NroLlamado = await Certi.ProximoNroLlamadoAsync())">
    <ListColumns>
        <DxGridDataColumn FieldName="NroLlamado" Caption="Nº llamado" Width="120px" />
        <DxGridDataColumn FieldName="CI" Caption="Cédula" Width="130px" DisplayFormat="0" />
        <DxGridDataColumn FieldName="FechaCertificacion" Caption="Fecha certif." DisplayFormat="d" Width="130px" />
        <DxGridDataColumn FieldName="FechaIni" Caption="Desde" DisplayFormat="d" Width="120px" />
        <DxGridDataColumn FieldName="FechaFin" Caption="Hasta" DisplayFormat="d" Width="120px" />
        <DxGridDataColumn FieldName="Efectiva" Caption="Efectiva" Width="100px" />
        @* Resto de campos: ocultos por defecto, disponibles en "Columnas" para que el usuario los habilite. *@
        <DxGridDataColumn FieldName="NroRecibo" Caption="Nº recibo" Visible="false" />
        <DxGridDataColumn FieldName="FechaRecibido" Caption="Recibido" DisplayFormat="d" Visible="false" />
        <DxGridDataColumn FieldName="CodAfeccionTipo" Caption="Tipo de afección" Visible="false">
            <CellDisplayTemplate Context="ctx">@LookupText(_afeccion, ctx.Value)</CellDisplayTemplate>
        </DxGridDataColumn>
        <DxGridDataColumn FieldName="CodCertificador" Caption="Certificador" Visible="false">
            <CellDisplayTemplate Context="ctx">@LookupText(_certificador, ctx.Value)</CellDisplayTemplate>
        </DxGridDataColumn>
        <DxGridDataColumn FieldName="CodSalidaTipo" Caption="Tipo de salida" Visible="false">
            <CellDisplayTemplate Context="ctx">@LookupText(_salida, ctx.Value)</CellDisplayTemplate>
        </DxGridDataColumn>
        <DxGridDataColumn FieldName="ImporteDeducible" Caption="Deducible" DisplayFormat="n2" Visible="false" />
        <DxGridDataColumn FieldName="Indicaciones" Caption="Indicaciones" Visible="false" />
        <DxGridDataColumn FieldName="Trabaja" Caption="Trabaja" Visible="false" />
    </ListColumns>
    <DetailHeader Context="c">
        Certificación Nº @c.NroLlamado — cédula @c.CI
    </DetailHeader>
    <ChildTabs Context="c">
        <DxTabPage Text="Prórrogas" TabIconCssClass="fa-solid fa-calendar-plus">
            <div class="p-2">
                @* Las prórrogas son a nivel afiliado (clave CI+Fecha); se filtran por la cédula de la certificación. *@
                <SgpaCrudView TEntity="CertificacionProrroga" Title="Prórrogas del afiliado"
                              FilterColumn="CI" FilterValue="c.CI" />
            </div>
        </DxTabPage>
    </ChildTabs>
</SgpaMasterDetailView>

@code {
    [Parameter] public int NroLlamado { get; set; }

    // Descripciones de los FK (código → texto) para los CellDisplayTemplate de las columnas FK.
    private Dictionary<string, string> _afeccion = new(), _certificador = new(), _salida = new();

    protected override async Task OnInitializedAsync()
    {
        _afeccion = await DictAsync(typeof(AfeccionTipo));
        _certificador = await DictAsync(typeof(Certificador));
        _salida = await DictAsync(typeof(SalidaTipo));
    }

    private async Task<Dictionary<string, string>> DictAsync(Type entidad)
    {
        var d = new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase);
        var items = await Lookups.GetAsync(entidad);
        if (items is not null)
            foreach (var i in items)
            {
                var k = i.Value?.ToString();
                if (!string.IsNullOrEmpty(k)) d[k] = i.Text;
            }
        return d;
    }

    private static string LookupText(Dictionary<string, string> dict, object? code)
        => code is null ? string.Empty
           : dict.TryGetValue(code.ToString()!, out var t) ? t : code.ToString()!;
}
